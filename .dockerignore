# Local build artifacts that would poison the docker build with Windows
# paths in project.assets.json (NuGet "fallback package folder" pointing
# to "C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages").
**/bin/
**/obj/

# Hub's wwwroot is build output (Web SPA gets published into it).
# IMPORTANT: do NOT exclude **/wwwroot blanket-style — Clawpilot.Web/wwwroot
# is real source.
src/Clawpilot.Hub/wwwroot/

.git/
.vs/
.vscode/
*.user
TestResults/
