@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject Magpilot.UI.Services.HubLogClient HubLog
@implements IDisposable
@using Magpilot.UI.Logging
@using Microsoft.Extensions.Logging

<MudThemeProvider Theme="MagpilotTheme.Default" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="@(new ThemeState(_isDarkMode, EventCallback.Factory.Create<bool>(this, SetDarkMode)))">
    <main class="full">
        @Body
    </main>
</CascadingValue>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool _isDarkMode = false;
    private const string DarkModeKey = "magpilot.darkMode";

    private async Task SetDarkMode(bool value)
    {
        _isDarkMode = value;
        try { await JS.InvokeVoidAsync("localStorage.setItem", DarkModeKey, value ? "true" : "false"); } catch { }
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        // Track navigation so each subsequent log event records which page
        // raised it. Saved by HubLogClient and shown in /admin/logs.
        Nav.LocationChanged += OnLocationChanged;
        HubLog.SetCurrentUrl(Nav.Uri);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => HubLog.SetCurrentUrl(e.Location);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Hydrate the runtime log-level gate from (a) the ?logLevel=X
        // query param (highest precedence -- a fresh URL wins over a
        // stored preference) and (b) localStorage. Until this fires the
        // gate sits at its default (Information), so framework + app
        // logs at startup are still emitted at the normal level.
        try
        {
            var fromUrl = ReadLogLevelFromUrl(Nav.Uri);
            if (fromUrl is not null)
            {
                LogLevelGate.Set(fromUrl.Value);
            }
            else
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", LogLevelGate.LocalStorageKey);
                var parsed = LogLevelGate.TryParse(stored);
                if (parsed is not null) LogLevelGate.Set(parsed.Value);
            }
        }
        catch { /* localStorage / URL parse failures keep the default */ }

        // Pick up the persisted dark mode + capture browser User-Agent into
        // the hub-log client so server-side viewer rows show which device
        // raised the error.
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", DarkModeKey);
            if (stored == "true" && !_isDarkMode)
            {
                _isDarkMode = true;
                StateHasChanged();
            }
        }
        catch { }

        try
        {
            var ua = await JS.InvokeAsync<string?>("eval", "navigator.userAgent");
            if (!string.IsNullOrEmpty(ua)) HubLog.SetUserAgent(ua);
        }
        catch { }

        // Install window.onerror + unhandledrejection -> CaptureJsError bridge.
        try { await JS.InvokeVoidAsync("magpilot.installErrorCapture"); }
        catch (Exception ex)
        {
            HubLog.LogError("installErrorCapture failed", ex.ToString(), category: nameof(MainLayout));
        }
    }

    private static LogLevel? ReadLogLevelFromUrl(string uri)
    {
        if (!Uri.TryCreate(uri, UriKind.Absolute, out var parsed)) return null;
        var query = parsed.Query;
        if (string.IsNullOrEmpty(query)) return null;
        var qs = System.Web.HttpUtility.ParseQueryString(query);
        return LogLevelGate.TryParse(qs[LogLevelGate.QueryParamName]);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
