@using System.Collections.ObjectModel
<div class="chat-view">
    <div class="messages">
        @foreach (var m in Messages)
        {
            var isThought = m.Role.Equals("thought", StringComparison.OrdinalIgnoreCase);
            if (isThought && !ShowThoughts) { continue; }
            <div class="msg msg-@m.Role.ToLowerInvariant()">
                <div class="role">@(isThought ? "thinking" : m.Role)</div>
                @if (isThought)
                {
                    <details class="thought" open>
                        <summary>thought</summary>
                        <MarkdownView Text="@m.Text" />
                    </details>
                }
                else if (m.Role.Equals("assistant", StringComparison.OrdinalIgnoreCase))
                {
                    <MarkdownView Text="@m.Text" />
                }
                else
                {
                    <pre class="text">@m.Text</pre>
                }
            </div>
        }
        @if (Thinking)
        {
            <div class="msg msg-assistant thinking-row">
                <div class="role">assistant</div>
                <div class="thinking" aria-label="thinking"><span></span><span></span><span></span></div>
            </div>
        }
        @if (PendingApproval is not null)
        {
            <div class="approval">
                <strong>Permission required:</strong> @PendingApproval.Title
                <div class="options">
                    @foreach (var o in PendingApproval.Options)
                    {
                        <button @onclick="() => OnApproval.InvokeAsync((PendingApproval.ApprovalId, o.OptionId))">
                            @o.Label
                        </button>
                    }
                </div>
            </div>
        }
    </div>
    <div class="composer">
        <textarea @bind="_draft" @bind:event="oninput"
                  placeholder="Message..." rows="3" disabled="@Disabled"></textarea>
        <button class="send" @onclick="Send" disabled="@(Disabled || string.IsNullOrWhiteSpace(_draft))">
            Send
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ObservableCollection<ChatMessage> Messages { get; set; } = default!;
    [Parameter] public ApprovalRequired? PendingApproval { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Thinking { get; set; }
    [Parameter] public bool ShowThoughts { get; set; } = true;
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public EventCallback<(string ApprovalId, string OptionId)> OnApproval { get; set; }

    private string _draft = "";

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        var text = _draft;
        _draft = "";
        await OnSend.InvokeAsync(text);
    }
}
