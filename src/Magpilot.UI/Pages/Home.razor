@page "/"
@page "/agents/{agent}"
@page "/agents/{agent}/sessions/{sessionId}"
@inject HubClient Hub
@inject HubLogClient HubLog
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable
@using System.Collections.ObjectModel
@using System.Text.Json
@using Magpilot.UI.Services

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       Class="d-md-none"
                       aria-label="Toggle navigation" />
        <MudText Typo="Typo.h6" Class="ml-1 mr-4">Magpilot</MudText>
        @if (Agent is not null)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">
                <MagpieMark Size="16" Class="mr-1" /> @Agent
            </MudChip>
            @if (_currentSessionTitle is not null)
            {
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="mx-1" />
                <MudText Typo="Typo.body2" Class="text-truncate" Style="max-width: 40vw;">@_currentSessionTitle</MudText>
            }
            @if (SessionId is not null)
            {
                <MudTooltip Text="@StreamStatusTooltip()">
                    @switch (_streamStatus)
                    {
                        case StreamStatus.Connected:
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Class="ml-2" />
                            break;
                        case StreamStatus.Reconnecting:
                            <MudProgressCircular Color="Color.Warning" Size="Size.Small" Indeterminate="true" Class="ml-2" />
                            break;
                        case StreamStatus.Offline:
                            <MudIconButton Icon="@Icons.Material.Filled.CloudOff"
                                           Color="Color.Error" Size="Size.Small" Class="ml-2"
                                           OnClick="HandleReconnectClick"
                                           aria-label="Reconnect" />
                            break;
                    }
                </MudTooltip>
            }
        }
        <MudSpacer />
        <MudTooltip Text="View central logs">
            <MudIconButton Icon="@Icons.Material.Filled.Article"
                           Color="Color.Inherit"
                           Href="/admin/logs"
                           aria-label="Logs" />
        </MudTooltip>
        <MudTooltip Text="@((Theme?.IsDark ?? false) ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@((Theme?.IsDark ?? false) ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@OnToggleDarkMode" />
        </MudTooltip>
        @if (_agents is { Count: > 0 })
        {
            <MudTooltip Text="@($"{_agents.Count} host{(_agents.Count == 1 ? string.Empty : "s")} online")">
                <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Small" Class="ml-2" />
            </MudTooltip>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Elevation="1"
               Color="Color.Surface">
        @if (Agent is null || _showHostsPane)
        {
            @* Hosts pane: pick a host. Hub icon sits in the same column as the *@
            @* host-row radio bullets so the leading edges line up vertically.   *@
            <div class="d-flex align-center gap-2 px-4 py-3">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Hosts</MudText>
            </div>

            @if (_agents is null)
            {
                <MudList T="string" Dense="true">
                    @for (var i = 0; i < 3; i++)
                    {
                        <MudListItem T="string" Disabled="true">
                            <MudSkeleton Width="80%" Height="20px" />
                        </MudListItem>
                    }
                </MudList>
            }
            else if (_agents.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mx-3 my-2">
                    No hosts discovered yet.
                </MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true" SelectedValue="@Agent" SelectedValueChanged="@OnAgentSelected">
                    @foreach (var a in _agents)
                    {
                        <MudListItem T="string" Value="@a.Name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@(a.Online ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                                         Color="@(a.Online ? Color.Success : Color.Default)"
                                         Size="Size.Small" />
                                <MudText Typo="Typo.body1">@a.Name</MudText>
                                @if (a.Flavors is { Count: > 0 } flavors && flavors.Any(f => f != "default"))
                                {
                                    <MudSpacer />
                                    @foreach (var f in flavors.Where(f => f != "default"))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">@f</MudChip>
                                    }
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }

            @if (Agent is not null && _showHostsPane)
            {
                @* Reassurance affordance: an explicit way back to the active   *@
                @* host's sessions, so the user isn't trapped if they bounced  *@
                @* into the hosts pane just to glance at the host list.        *@
                <MudDivider Class="my-2" />
                <div class="px-3 pb-3">
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="@(() => _showHostsPane = false)">
                        Back to @Agent
                    </MudButton>
                </div>
            }
        }
        else
        {
            @* Sessions pane: focused on a single host. Back arrow returns to *@
            @* the hosts pane (without leaving the open chat).                *@
            <div class="d-flex align-center gap-1 px-2 py-2"
                 style="border-bottom: 1px solid var(--mud-palette-divider);">
                <MudTooltip Text="Back to hosts">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Size="Size.Small"
                                   OnClick="@GoBackToHosts"
                                   aria-label="Back to hosts" />
                </MudTooltip>
                @if (_agents?.FirstOrDefault(a => a.Name == Agent) is { } currentAgent)
                {
                    <MudIcon Icon="@(currentAgent.Online ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                             Color="@(currentAgent.Online ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                }
                <MudText Typo="Typo.subtitle1" Class="ml-1 text-truncate" Style="min-width: 0;">@Agent</MudText>
                <MudSpacer />
                <MudTooltip Text="Refresh session list">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@RefreshSessions"
                                   Disabled="@_sessionsRefreshing"
                                   aria-label="Refresh session list" />
                </MudTooltip>
                <MudTooltip Text="New chat">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@OpenNewSessionDialog"
                                   aria-label="New chat" />
                </MudTooltip>
            </div>

            @if (_sessions is null)
            {
                <MudList T="string" Dense="true">
                    @for (var i = 0; i < 4; i++)
                    {
                        <MudListItem T="string" Disabled="true">
                            <MudSkeleton Width="90%" Height="20px" />
                            <MudSkeleton Width="50%" Height="14px" />
                        </MudListItem>
                    }
                </MudList>
            }
            else if (_sessions.Count == 0)
            {
                <MudPaper Class="mx-3 my-3 pa-3 d-flex flex-column align-center" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Class="my-2" Color="Color.Default">No sessions on @Agent yet</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenNewSessionDialog">
                        Start one
                    </MudButton>
                </MudPaper>
            }
            else
            {
                @foreach (var (state, label, group) in EnumerateGroups(_sessions))
                {
                    var expanded = _expandedGroups.Contains(state);
                    var visible = expanded ? group : group.Take(CollapsedLimit).ToList();
                    var hidden = group.Count - visible.Count;
                    var (chipColor, chipIcon) = GroupVisuals(state);

                    <MudListSubheader Class="d-flex align-center gap-1 px-4">
                        <MudIcon Icon="@chipIcon" Size="Size.Small" Color="@chipColor" />
                        <MudText Typo="Typo.overline" Class="ml-1">@label</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Class="ml-1">@group.Count</MudChip>
                    </MudListSubheader>

                    <MudList T="string" Dense="true" SelectedValue="@SessionId" SelectedValueChanged="@OnSessionSelected">
                        @foreach (var s in visible)
                        {
                            <MudListItem T="string" Value="@s.Id" Class="py-2">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Class="text-truncate" Style="font-weight: 500;">
                                        @(s.Summary ?? s.Id[..8])
                                    </MudText>
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                                        @if (!string.IsNullOrWhiteSpace(s.Repository))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Icon="@Icons.Material.Filled.FolderOpen">
                                                @s.Repository@(string.IsNullOrWhiteSpace(s.Branch) ? string.Empty : $"@{s.Branch}")
                                            </MudChip>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(s.Cwd))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Default" Class="text-truncate" Style="max-width: 200px;" title="@s.Cwd">
                                                @ShortPath(s.Cwd)
                                            </MudText>
                                        }
                                        @if (s.UpdatedAt is { } ua)
                                        {
                                            <MudSpacer />
                                            <MudText Typo="Typo.caption" Color="Color.Default">@RelativeTime(ua)</MudText>
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>

                    @if (hidden > 0)
                    {
                        <div class="px-4 pb-2">
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ExpandMore"
                                       OnClick="@(() => ToggleGroup(state))">
                                Show @hidden more
                            </MudButton>
                        </div>
                    }
                    else if (expanded && group.Count > CollapsedLimit)
                    {
                        <div class="px-4 pb-2">
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.ExpandLess"
                                       OnClick="@(() => ToggleGroup(state))">
                                Show less
                            </MudButton>
                        </div>
                    }
                }
            }
        }
    </MudDrawer>

    <MudMainContent Class="d-flex flex-column" Style="height: 100dvh; overflow: hidden;">
        @if (_newSessionOpen)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudText Typo="Typo.h5" Class="mb-2">New chat on @Agent</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
                        Pick a working directory for the conversation. Leave blank to use the agent's default.
                    </MudText>
                    <MudAutocomplete T="string" Label="Working directory"
                                     @bind-Value="_newSessionCwd"
                                     SearchFunc="@SearchCwds"
                                     Variant="Variant.Outlined"
                                     CoerceValue="true"
                                     ResetValueOnEmptyText="false"
                                     Placeholder="(leave blank for agent default)"
                                     Class="mb-4" />
                    @if (_currentAgentSupportsAgency)
                    {
                        <MudCheckBox T="bool" @bind-Value="_newSessionUseAgency" Color="Color.Primary"
                                     Label="Wrap with agency (extra MCP servers)"
                                     Class="mb-4" />
                    }
                    @if (_newSessionError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_newSessionError</MudAlert>
                    }
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" Disabled="@_newSessionBusy" OnClick="@CancelNewSession">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="@_newSessionBusy"
                                   OnClick="@ConfirmNewSession"
                                   StartIcon="@(_newSessionBusy ? null : Icons.Material.Filled.Send)">
                            @if (_newSessionBusy)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Creating...</span>
                            }
                            else
                            {
                                <span>Create</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (_pendingOrphan is not null)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                        <MudText Typo="Typo.h6">Adopt running session?</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Class="mb-2">
                        This session is held by another process (PID <strong>@_pendingOrphan.OwnerPid</strong>).
                        Adopting will <em>kill</em> that process and load the session under magpilot.
                    </MudText>
                    <MudPaper Class="pa-3 my-3" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.caption" Color="Color.Default">@(_pendingOrphan.Summary ?? _pendingOrphan.Id)</MudText>
                    </MudPaper>
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" OnClick="@CancelOrphanAdopt">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                                   OnClick="@ConfirmOrphanAdopt">
                            Kill PID @_pendingOrphan.OwnerPid and adopt
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (Agent is not null && SessionId is not null)
        {
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            }
            <div class="chat-toolbar-mud px-3 py-1 d-flex align-center">
                <MudSwitch T="bool" Color="Color.Primary" Size="Size.Small"
                           Value="_showThoughts" ValueChanged="@SetShowThoughts"
                           Label="Show thinking" />
            </div>
            @if (_streamStatus == StreamStatus.Offline)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mx-3 my-2"
                          ContentAlignment="HorizontalAlignment.Left">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">
                            Connection to the agent dropped and didn't recover.
                        </MudText>
                        <MudSpacer />
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="HandleReconnectClick">
                            Reconnect
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            @if (_pendingForceTake is { } pending)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mx-3 my-2"
                          ContentAlignment="HorizontalAlignment.Left">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">
                            Terminal session (PID @pending.HostPid) didn't release for "@TruncatePreview(pending.Text)".
                        </MudText>
                        <MudSpacer />
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                                   OnClick="HandleForceTake">
                            Take over from terminal
                        </MudButton>
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Close"
                                       OnClick="HandleCancelForceTake" aria-label="Dismiss" />
                    </MudStack>
                </MudAlert>
            }
            <ChatView @ref="_chatView"
                      Messages="@_messages"
                      PendingApproval="@_pendingApproval"
                      Disabled="@(_busy || _loading)"
                      Thinking="@_thinking"
                      ShowThoughts="@_showThoughts"
                      HasMore="@_hasMore"
                      OnLoadMore="HandleLoadOlder"
                      OnSend="HandleSend"
                      OnApproval="HandleApproval" />
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="flex: 1;">
                <MagpieMark Size="96" Glow="true" />
                <MudText Typo="Typo.h4" Class="mt-3 mb-2">Magpilot</MudText>
                <MudText Typo="Typo.body1" Color="Color.Default" Align="Align.Center">
                    Pick a host on the left to see its sessions, or start a new chat.
                </MudText>
            </MudContainer>
        }
    </MudMainContent>
</MudLayout>

@code {
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [Parameter] public string? Agent { get; set; }
    [Parameter] public string? SessionId { get; set; }

    [CascadingParameter] public ThemeState? Theme { get; set; }

    private async Task OnToggleDarkMode()
    {
        if (Theme is null) return;
        await Theme.Set.InvokeAsync(!Theme.IsDark);
    }

    private List<AgentInfo>? _agents;
    private List<SessionInfo>? _sessions;
    private bool _drawerOpen = true;
    private bool _showHostsPane;
    private bool _sessionsRefreshing;
    private readonly HashSet<SessionState> _expandedGroups = new();
    private readonly ObservableCollection<ChatMessage> _messages = new();
    private ChatMessage? _streamingAssistant;
    private ChatMessage? _streamingThought;
    private ApprovalRequired? _pendingApproval;
    private CancellationTokenSource? _streamCts;
    private bool _busy;
    private bool _loading;
    /// <summary>
    /// When true, content events (user/assistant/thought/tool/approval)
    /// arriving on the stream between LoadStarted and HistoryDone are
    /// dropped instead of appended to <see cref="_messages"/>. Set by
    /// <see cref="StartStreamingAsync"/> whenever the caller is loading
    /// the session into ACP (<c>load: true</c>) but has already populated
    /// the visible chat from <c>restoreFrom</c> (i.e. the paged
    /// /history?tail=50 disk projection). Without this, opening a large
    /// Dormant session re-streams every historical event on top of the
    /// tail snapshot -- doubling the chat AND defeating the whole
    /// point of paging.
    /// </summary>
    private bool _suppressReplayEvents;
    private bool _thinking;
    // Paging cursor for the demand-load-older flow (see HandleLoadOlder).
    // _oldestCursor is the ordinal id of the oldest entry currently in
    // _messages; pass back as ?before= on the next history call. Reset
    // (along with _hasMore) when the session changes -- see StartStreamingAsync.
    private int _oldestCursor;
    private bool _hasMore;
    private ChatView? _chatView;
    /// <summary>
    /// When the agent refuses a prompt because a magpilot launcher holds
    /// the session AND the wrapper failed to release within the polite-knock
    /// window, we stash the user's prompt here so they can hit "Take over
    /// from terminal" to force-acquire and retry. Cleared on success or
    /// explicit cancel.
    /// </summary>
    private PendingForceTake? _pendingForceTake;
    private string? _streamingFor;
    private int _streamGeneration;
    // Number of consecutive auto-reconnect attempts since the last successful
    // event. Reset to 0 whenever the stream pump receives any payload, or when
    // the user navigates to a different session. Capped to avoid infinite
    // reconnect loops if the agent is genuinely down.
    private int _streamReconnectAttempts;
    /// <summary>
    /// User-visible connection state for the currently-open session's SSE
    /// stream. Drives the AppBar status pill + the "give up" alert.
    /// Connected = any event received in the last reconnect cycle.
    /// Reconnecting = stream dropped, exponential backoff in progress.
    /// Offline = exhausted maxAttempts reconnect tries, user action required.
    /// </summary>
    private enum StreamStatus { Connected, Reconnecting, Offline }
    private StreamStatus _streamStatus = StreamStatus.Connected;
    /// <summary>
    /// Next retry timestamp during Reconnecting. Used to render a
    /// countdown in the status pill tooltip. Null when not reconnecting.
    /// </summary>
    private DateTime? _reconnectNextAttemptAt;
    private SessionInfo? _pendingOrphan;
    private bool _newSessionOpen;
    private string _newSessionCwd = "";
    private bool _newSessionUseAgency;
    private string? _newSessionError;
    private bool _newSessionBusy;
    private List<string> _cwdSuggestions = new();

    private sealed record PendingForceTake(string Text, int HostPid);

    // Per-session in-memory snapshot of messages, keyed by "{Agent}/{SessionId}".
    // We keep this so switching back to an Owned session restores its
    // chat history without re-issuing session/load (ACP rejects double-load
    // with -32602 "already loaded"). Snapshots are written when leaving a
    // session and refreshed on every Apply() while viewing it.
    private readonly Dictionary<string, List<ChatMessage>> _msgCache = new();
    private bool _showThoughts = true;
    private const string ShowThoughtsKey = "magpilot.showThoughts";

    protected override async Task OnInitializedAsync()
    {
        try { _agents = await Hub.ListAgentsAsync(); }
        catch (Exception ex)
        {
            _agents = [];
            HubLog.LogError($"ListAgentsAsync failed: {ex.Message}", ex.ToString(), category: nameof(Home));
            Snackbar.Add($"Could not load hosts: {ex.Message}", Severity.Error);
        }

        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ShowThoughtsKey);
            if (stored is not null) _showThoughts = stored == "true";
        }
        catch { }
    }

    private async Task ToggleShowThoughts(ChangeEventArgs e)
    {
        _showThoughts = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var p) && p;
        try { await JS.InvokeVoidAsync("localStorage.setItem", ShowThoughtsKey, _showThoughts ? "true" : "false"); }
        catch { }
    }

    private async Task SetShowThoughts(bool value)
    {
        _showThoughts = value;
        try { await JS.InvokeVoidAsync("localStorage.setItem", ShowThoughtsKey, value ? "true" : "false"); }
        catch { }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnAgentSelected(string? name)
    {
        _showHostsPane = false;
        if (string.IsNullOrEmpty(name) || name == Agent) return;
        Nav.NavigateTo($"/agents/{name}");
    }

    private void GoBackToHosts() => _showHostsPane = true;

    private void OnSessionSelected(string? id)
    {
        if (string.IsNullOrEmpty(id) || id == SessionId) return;
        Nav.NavigateTo($"/agents/{Agent}/sessions/{id}");
    }

    private Task<IEnumerable<string>> SearchCwds(string? value, CancellationToken ct)
    {
        IEnumerable<string> results = string.IsNullOrWhiteSpace(value)
            ? _cwdSuggestions
            : _cwdSuggestions.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private static (Color color, string icon) GroupVisuals(SessionState state) => state switch
    {
        SessionState.Owned   => (Color.Success, Icons.Material.Filled.RadioButtonChecked),
        SessionState.Locked  => (Color.Warning, Icons.Material.Filled.Lock),
        SessionState.Dormant => (Color.Default, Icons.Material.Filled.History),
        _                    => (Color.Default, Icons.Material.Filled.HelpOutline),
    };

    private static string RelativeTime(DateTimeOffset when)
    {
        var delta = DateTimeOffset.UtcNow - when;
        if (delta.TotalSeconds < 60)  return "just now";
        if (delta.TotalMinutes < 60)  return $"{(int)delta.TotalMinutes}m";
        if (delta.TotalHours < 24)    return $"{(int)delta.TotalHours}h";
        if (delta.TotalDays < 7)      return $"{(int)delta.TotalDays}d";
        if (delta.TotalDays < 30)     return $"{(int)(delta.TotalDays / 7)}w";
        if (delta.TotalDays < 365)    return $"{(int)(delta.TotalDays / 30)}mo";
        return $"{(int)(delta.TotalDays / 365)}y";
    }

    private static string ShortPath(string cwd)
    {
        // Compress any /home/<user>/ prefix to ~/ for narrow display chips.
        // Generic so any deployment's user accounts collapse cleanly --
        // we don't want platform-specific user-name strings here.
        var compressed = System.Text.RegularExpressions.Regex.Replace(
            cwd, @"^/home/[^/]+/", "~/");
        if (compressed.Length <= 28) return compressed;
        return "..." + compressed[^25..];
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Agent is not null)
        {
            try { _sessions = await Hub.ListSessionsAsync(Agent); }
            catch (Exception ex)
            {
                HubLog.LogError($"ListSessionsAsync failed for {Agent}: {ex.Message}", ex.ToString(),
                    category: nameof(Home), sessionId: SessionId,
                    extra: new { agent = Agent });
                _sessions = [];
                Snackbar.Add($"Could not load sessions on {Agent}: {ex.Message}", Severity.Error);
            }
        }

        if (Agent is not null && SessionId is not null && _streamingFor != $"{Agent}/{SessionId}")
        {
            // Claim the slot synchronously, BEFORE any awaits, so a re-entrant
            // call (cascading parameter change, navigation event, etc.) sees
            // the new target and skips this branch instead of starting a
            // duplicate stream task.
            var target = $"{Agent}/{SessionId}";
            _streamingFor = target;

            // Snapshot the previous session before tearing down its stream so
            // we can rehydrate when the user navigates back.
            SnapshotCurrentMessages();

            await StopStreamingAsync();
            _pendingOrphan = null;

            var info = _sessions?.FirstOrDefault(s => s.Id == SessionId);
            if (info?.State == SessionState.Locked)
            {
                // Show confirmation; user must click "Adopt" to proceed.
                _pendingOrphan = info;
                _streamingFor = $"{Agent}/{SessionId}";
                StateHasChanged();
                return;
            }

            // If we have a cached snapshot AND the session is still loaded
            // into ACP (Owned), restore the snapshot and connect WITHOUT
            // requesting a load -- ACP would reject session/load on an
            // already-loaded session.
            //
            // For Dormant sessions, request load=true so ACP loads the
            // session into its multiplex child -- BUT also pre-fetch the
            // tail of /history so we can paint the chat instantly and
            // suppress the giant replay storm that session/load would
            // otherwise stream in (see _suppressReplayEvents). Without
            // this, opening a long-running Dormant session animates every
            // historical event on top of itself.
            //
            // For Owned-without-cache (a fresh browser tab opening a
            // session that was loaded into ACP by another client, e.g.
            // the WhatsApp sidecar), neither path works: we can't
            // load=true (ACP rejects double-load) and we have no in-tab
            // cache. Fall back to reading the on-disk events.jsonl via
            // the agent's /history endpoint.
            var key = $"{Agent}/{SessionId}";
            var hasCache = _msgCache.TryGetValue(key, out var cached);
            if (hasCache && info?.State == SessionState.Owned)
            {
                await StartStreamingAsync(load: false, force: false, restoreFrom: cached);
            }
            else if (!hasCache && info?.State == SessionState.Owned)
            {
                var fromDisk = await TryLoadTailHistoryAsync(50);
                await StartStreamingAsync(load: false, force: false, restoreFrom: fromDisk);
            }
            else
            {
                // Dormant. Pre-paint from disk projection, then request
                // load=true. _suppressReplayEvents takes care of the
                // replay flood.
                var fromDisk = await TryLoadTailHistoryAsync(50);
                await StartStreamingAsync(load: true, force: false, restoreFrom: fromDisk);
            }
        }
    }

    /// <summary>
    /// Fetch the most recent <paramref name="tail"/> entries from the
    /// agent's /history endpoint (which projects events.jsonl). Sets
    /// <see cref="_oldestCursor"/> and <see cref="_hasMore"/> as a
    /// side-effect so the "Load older messages" affordance works for
    /// every caller. Returns null on error -- the caller should still
    /// start the stream, just without a pre-paint.
    /// </summary>
    private async Task<List<ChatMessage>?> TryLoadTailHistoryAsync(int tail)
    {
        if (Agent is null || SessionId is null) return null;
        try
        {
            var page = await Hub.GetHistoryAsync(Agent, SessionId, tail: tail);
            if (page is null) return null;
            _oldestCursor = page.OldestCursor;
            _hasMore = page.HasMore;
            return CollapseLegacyToolEntries(page.Entries)
                .Select(r => new ChatMessage
                {
                    Role = r.Role,
                    Text = r.Text,
                    ToolCallId = r.ToolCallId,
                    ToolStatus = r.ToolStatus,
                })
                .ToList();
        }
        catch (Exception ex)
        {
            HubLog.LogError($"GetHistoryAsync failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), sessionId: SessionId,
                extra: new { agent = Agent });
            return null;
        }
    }

    /// <summary>
    /// Pre-v0.1.8 agents projected each ACP tool call as TWO history
    /// entries: "[start] toolname" and "[end] ok|fail". Newer agents
    /// emit a single entry with <see cref="HistoryEntry.ToolStatus"/>
    /// set on the wire. Collapse the legacy two-row shape into the
    /// single-row shape so the new SPA renders a unified chip
    /// regardless of which agent version is serving it.
    /// </summary>
    private static IEnumerable<HubClient.HistoryEntry> CollapseLegacyToolEntries(
        IEnumerable<HubClient.HistoryEntry> entries)
    {
        const string startPrefix = "[start] ";
        const string endPrefix = "[end] ";
        var collapsed = new List<HubClient.HistoryEntry>();
        var indexById = new Dictionary<string, int>(StringComparer.Ordinal);
        foreach (var e in entries)
        {
            if (e.Role == "tool" && e.Text.StartsWith(startPrefix, StringComparison.Ordinal))
            {
                var title = e.Text[startPrefix.Length..];
                var collapsedEntry = e with { Text = title, ToolStatus = ToolStatus.Pending };
                if (!string.IsNullOrEmpty(e.ToolCallId))
                    indexById[e.ToolCallId] = collapsed.Count;
                collapsed.Add(collapsedEntry);
            }
            else if (e.Role == "tool" && e.Text.StartsWith(endPrefix, StringComparison.Ordinal))
            {
                var success = !e.Text.StartsWith("[end] fail", StringComparison.Ordinal);
                if (!string.IsNullOrEmpty(e.ToolCallId)
                    && indexById.TryGetValue(e.ToolCallId, out var idx))
                {
                    collapsed[idx] = collapsed[idx] with
                    {
                        ToolStatus = success ? ToolStatus.Ok : ToolStatus.Fail,
                    };
                }
                // No matching [start]: drop. The old SPA used to render
                // a standalone "[end] ok" chip; the new unified-chip
                // model has nowhere to attach it. This is a graceful
                // degradation for malformed legacy logs.
            }
            else
            {
                collapsed.Add(e);
            }
        }
        return collapsed;
    }

    /// <summary>
    /// Find the most recent "tool" message in <see cref="_messages"/>
    /// matching <paramref name="toolCallId"/>. Used by Apply() when a
    /// ToolCallEnd arrives, to mutate the existing pending chip in
    /// place. Iterates from the end since the matching start is
    /// usually the most recent tool message.
    /// </summary>
    private ChatMessage? FindToolMessage(string? toolCallId)
    {
        if (string.IsNullOrEmpty(toolCallId)) return null;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            var m = _messages[i];
            if (m.Role == "tool" && m.ToolCallId == toolCallId) return m;
        }
        return null;
    }

    private async Task ConfirmOrphanAdopt()
    {
        if (_pendingOrphan is null) return;
        var info = _pendingOrphan;
        _pendingOrphan = null;
        StateHasChanged();
        // Same Dormant treatment: pre-paint from disk, request the load,
        // suppress the replay flood. force:true kills the prior owner PID.
        var fromDisk = await TryLoadTailHistoryAsync(50);
        await StartStreamingAsync(load: true, force: true, restoreFrom: fromDisk);
    }

    private void CancelOrphanAdopt()
    {
        _pendingOrphan = null;
        _streamingFor = null;
        Nav.NavigateTo($"/agents/{Agent}");
    }

    private async Task RefreshSessions()
    {
        if (Agent is null || _sessionsRefreshing) return;
        _sessionsRefreshing = true;
        StateHasChanged();
        try
        {
            // Same call as OnParametersSetAsync uses, but triggered on
            // demand from the AppBar refresh button so the user can pick
            // up sessions started outside the SPA (e.g. magpilot CLI on
            // a host, a fresh terminal magpilot session, or a sidecar's
            // pinned session) without doing a full page reload.
            var fresh = await Hub.ListSessionsAsync(Agent);
            _sessions = fresh;
        }
        catch (Exception ex)
        {
            HubLog.LogError($"RefreshSessions failed for {Agent}: {ex.Message}", ex.ToString(),
                category: nameof(Home), extra: new { agent = Agent });
            Snackbar.Add($"Could not refresh sessions on {Agent}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sessionsRefreshing = false;
            StateHasChanged();
        }
    }

    private void SelectAgent(string name)
    {
        Nav.NavigateTo($"/agents/{name}");
    }

    private void ToggleGroup(SessionState state)
    {
        if (!_expandedGroups.Add(state))
        {
            _expandedGroups.Remove(state);
        }
    }

    /// <summary>
    /// Cap on items shown per group before "Load more" is required.
    /// </summary>
    private const int CollapsedLimit = 5;

    /// <summary>
    /// Group the server-sorted (UpdatedAt DESC) session list by SessionState
    /// and return them in display order. Most-actionable group first:
    /// Active (we own it) -> Locked (held by someone else) -> Past.
    /// Empty groups are skipped.
    /// </summary>
    private static IEnumerable<(SessionState State, string Label, List<SessionInfo> Group)>
        EnumerateGroups(IEnumerable<SessionInfo> sessions)
    {
        var byState = sessions.GroupBy(s => s.State).ToDictionary(g => g.Key, g => g.ToList());
        var ordered = new (SessionState State, string Label)[]
        {
            (SessionState.Owned,   "Active"),
            (SessionState.Locked,  "Locked"),
            (SessionState.Dormant, "Past"),
        };
        foreach (var (state, label) in ordered)
        {
            if (byState.TryGetValue(state, out var group) && group.Count > 0)
            {
                yield return (state, label, group);
            }
        }
    }

    private void GoBackToSidebar()
    {
        // Mobile: navigate "up" from a session to the agent's session list,
        // which on narrow viewports renders as the full-width sidebar page.
        if (Agent is not null)
        {
            Nav.NavigateTo($"/agents/{Agent}");
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    private string? _currentSessionTitle =>
        _sessions?.FirstOrDefault(s => s.Id == SessionId) is { } s
            ? (s.Summary ?? s.Id[..8])
            : null;

    /// <summary>
    /// True when the current Agent advertises the "agency" flavor (i.e. the
    /// `agency` CLI is installed on that host). Used to gate the "Wrap with
    /// agency" checkbox in the new session dialog.
    /// </summary>
    private bool _currentAgentSupportsAgency =>
        _agents?.FirstOrDefault(a => a.Name == Agent)?.Flavors?.Contains("agency") == true;

    private void OpenSession(SessionInfo s)
    {
        Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
    }

    private void OpenNewSessionDialog()
    {
        if (Agent is null) return;
        // Build cwd suggestions from existing sessions (most-recent first, deduped).
        _cwdSuggestions = (_sessions ?? new())
            .Where(s => !string.IsNullOrWhiteSpace(s.Cwd))
            .OrderByDescending(s => s.UpdatedAt)
            .Select(s => s.Cwd!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(20)
            .ToList();
        _newSessionCwd = _cwdSuggestions.FirstOrDefault() ?? "";
        _newSessionUseAgency = false;
        _newSessionError = null;
        _newSessionBusy = false;
        _newSessionOpen = true;
    }

    private void CancelNewSession()
    {
        _newSessionOpen = false;
        _newSessionError = null;
    }

    private async Task ConfirmNewSession()
    {
        if (Agent is null) return;
        _newSessionBusy = true;
        _newSessionError = null;
        try
        {
            var cwd = string.IsNullOrWhiteSpace(_newSessionCwd) ? null : _newSessionCwd.Trim();
            var s = await Hub.NewSessionAsync(Agent, cwd, _newSessionUseAgency);
            if (s is null) { _newSessionError = "Server returned no session"; _newSessionBusy = false; return; }
            // Instant-insert: prepend the new session to the visible list
            // before navigating, so the user sees it appear immediately.
            _sessions ??= new List<SessionInfo>();
            if (!_sessions.Any(x => x.Id == s.Id))
                _sessions.Insert(0, s);
            _newSessionOpen = false;
            Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
            // Reconcile in the background to pick up server-filled fields.
            _ = Task.Run(async () =>
            {
                try
                {
                    var fresh = await Hub.ListSessionsAsync(Agent);
                    await InvokeAsync(() => { _sessions = fresh; StateHasChanged(); });
                }
                catch { }
            });
        }
        catch (Exception ex)
        {
            _newSessionError = ex.Message;
            _newSessionBusy = false;
        }
    }

    private async Task NewSession()
    {
        if (Agent is null) return;
        try
        {
            var s = await Hub.NewSessionAsync(Agent, null);
            if (s is not null)
            {
                _sessions = await Hub.ListSessionsAsync(Agent);
                Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
            }
        }
        catch (Exception ex)
        {
            HubLog.LogError($"NewSession failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), extra: new { agent = Agent });
        }
    }

    private void SnapshotCurrentMessages()
    {
        if (_streamingFor is null || _messages.Count == 0) return;
        // Deep-clone the message records so subsequent mutations to the
        // observable collection (Clear, Add) don't poke the cached snapshot.
        _msgCache[_streamingFor] = _messages
            .Select(m => new ChatMessage
            {
                Role = m.Role,
                Text = m.Text,
                ToolCallId = m.ToolCallId,
                ToolStatus = m.ToolStatus,
            })
            .ToList();
    }

    private async Task StartStreamingAsync(bool load = false, bool force = false, List<ChatMessage>? restoreFrom = null, bool isReconnect = false)
    {
        if (Agent is null || SessionId is null) return;

        // Defensive: if a previous stream task is still alive (caller didn't
        // StopStreamingAsync, or a race in OnParametersSetAsync), cancel it
        // before installing a new CTS. Without this, the old Task.Run keeps
        // pumping events into Apply() in parallel with the new one, doubling
        // every assistant chunk. (Reproduces as character-interleaving in
        // the streaming bubble.)
        if (_streamCts is not null)
        {
            try { await _streamCts.CancelAsync(); }
            catch { /* already cancelled */ }
            _streamCts.Dispose();
            _streamCts = null;
        }

        _messages.Clear();
        _streamingAssistant = null;
        if (restoreFrom is not null)
        {
            foreach (var m in restoreFrom)
                _messages.Add(new ChatMessage
                {
                    Role = m.Role,
                    Text = m.Text,
                    ToolCallId = m.ToolCallId,
                    ToolStatus = m.ToolStatus,
                });
        }
        _loading = load;
        // Drop ACP history-replay events from session/load when the chat
        // was already populated from the disk projection. See field comment.
        _suppressReplayEvents = load && restoreFrom is not null;
        if (!isReconnect)
        {
            _streamReconnectAttempts = 0;
            _streamStatus = StreamStatus.Connected;
            _reconnectNextAttemptAt = null;
            // Reset paging cursor on a real session switch UNLESS the
            // caller already populated _oldestCursor / _hasMore from a
            // pre-stream /history fetch (TryLoadTailHistoryAsync sets
            // them before calling StartStreamingAsync). If we clobber
            // unconditionally, the "Load older messages" affordance
            // never shows for Owned-no-cache or Dormant sessions.
            if (restoreFrom is null)
            {
                _oldestCursor = 0;
                _hasMore = false;
            }
        }
        _streamCts = new CancellationTokenSource();
        _streamingFor = $"{Agent}/{SessionId}";
        var ct = _streamCts.Token;
        var agent = Agent;
        var sid = SessionId;
        var streamId = ++_streamGeneration;
        Console.WriteLine($"[stream {streamId}] start agent={agent} sid={sid} load={load} reconnect={isReconnect}");
        _ = Task.Run(async () =>
        {
            var gotAnyEvent = false;
            try
            {
                try
                {
                    await foreach (var evt in Hub.StreamAsync(agent, sid, load, force, ct))
                    {
                        if (streamId != _streamGeneration)
                        {
                            // A newer stream task has taken over; this one is stale.
                            Console.WriteLine($"[stream {streamId}] stale, dropping {evt.GetType().Name}");
                            return;
                        }
                        gotAnyEvent = true;
                        _streamReconnectAttempts = 0;
                        if (_streamStatus != StreamStatus.Connected)
                        {
                            _streamStatus = StreamStatus.Connected;
                            _reconnectNextAttemptAt = null;
                        }
                        await InvokeAsync(() => Apply(evt));
                    }
                }
                catch (OperationCanceledException)
                {
                    // User navigated or component disposed. Don't reconnect.
                    return;
                }
                catch (Exception ex)
                {
                    // The stream surfaced a transport error that HubClient.StreamAsync
                    // didn't intercept (e.g. a Json deserialize blow-up inside Apply
                    // that escapes InvokeAsync, or an exception from a 3rd-party event
                    // handler). Log it, fall into the reconnect block below -- the
                    // chat should keep trying to recover, not die silently. (Prior
                    // behaviour: log + return, leaving _streamStatus stuck on
                    // Connected and the SPA frozen until refresh.)
                    HubLog.LogError($"[stream {streamId}] {ex.Message}", ex.ToString(),
                        category: nameof(Home), sessionId: sid,
                        extra: new { agent, generation = streamId });
                    Console.Error.WriteLine($"[stream {streamId}] {ex.Message}");
                }

                // Reached when the SSE stream ended -- either naturally (e.g.
                // mobile browser backgrounded the tab and HubClient.StreamAsync
                // yield-broke), or after a caught exception above. If the user
                // is still on this session, transparently reconnect with the
                // existing message snapshot so the chat doesn't appear frozen.
                if (ct.IsCancellationRequested) return;
                if (streamId != _streamGeneration) return;
                if (_streamingFor != $"{agent}/{sid}") return;

                var attempt = ++_streamReconnectAttempts;
                const int maxAttempts = 8;
                if (attempt > maxAttempts)
                {
                    HubLog.LogError(
                        $"[stream {streamId}] giving up after {attempt - 1} reconnect attempts",
                        stack: null, category: nameof(Home), sessionId: sid,
                        extra: new { agent, generation = streamId });
                    Console.Error.WriteLine($"[stream {streamId}] giving up after {attempt - 1} reconnect attempts");
                    _streamStatus = StreamStatus.Offline;
                    _reconnectNextAttemptAt = null;
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                // Exponential backoff capped at 10s. Note: Task.Delay is heavily
                // throttled while a tab is hidden, so a backgrounded phone won't
                // burn battery on retry storms -- the delay naturally extends
                // until the tab becomes visible again.
                var delaySec = Math.Min(10, 1 << Math.Min(attempt - 1, 4));
                Console.WriteLine($"[stream {streamId}] disconnected (gotAny={gotAnyEvent}); reconnect attempt {attempt} in {delaySec}s");
                _streamStatus = StreamStatus.Reconnecting;
                _reconnectNextAttemptAt = DateTime.UtcNow.AddSeconds(delaySec);
                await InvokeAsync(StateHasChanged);
                try { await Task.Delay(TimeSpan.FromSeconds(delaySec), ct); }
                catch (OperationCanceledException) { return; }

                if (ct.IsCancellationRequested) return;
                if (streamId != _streamGeneration) return;
                if (_streamingFor != $"{agent}/{sid}") return;

                var snapshot = _messages
                    .Select(m => new ChatMessage
                    {
                        Role = m.Role,
                        Text = m.Text,
                        ToolCallId = m.ToolCallId,
                        ToolStatus = m.ToolStatus,
                    })
                    .ToList();
                await InvokeAsync(() => StartStreamingAsync(load: false, force: false, restoreFrom: snapshot, isReconnect: true));
            }
            catch (OperationCanceledException)
            {
                // Outer cancellation (component disposed mid-reconnect).
            }
            catch (Exception ex)
            {
                // Outermost catch: anything from the reconnect logic itself
                // (InvokeAsync after dispose, recursive StartStreamingAsync
                // throwing, etc.) lands here. Logged at the central sink so
                // it's debuggable, but NEVER bubbles to Blazor's unhandled-
                // exception handler (which would pop the "An unhandled error
                // has occurred. Reload" yellow banner and force a refresh).
                HubLog.LogError($"[stream {streamId}] pump task crashed: {ex.Message}", ex.ToString(),
                    category: nameof(Home), sessionId: sid,
                    extra: new { agent, generation = streamId, fatal = true });
                Console.Error.WriteLine($"[stream {streamId}] pump task crashed: {ex.Message}");
                // Try to surface to the user via the offline UI rather than
                // leaving the chat in a phantom-Connected state.
                try
                {
                    await InvokeAsync(() =>
                    {
                        _streamStatus = StreamStatus.Offline;
                        _reconnectNextAttemptAt = null;
                        StateHasChanged();
                    });
                }
                catch { /* component truly gone; nothing useful to do */ }
            }
        }, ct);

        if (load)
        {
            // After load completes, refresh the session list so the badge updates.
            _ = Task.Run(async () =>
            {
                while (!ct.IsCancellationRequested && _loading)
                    await Task.Delay(250, ct);
                try
                {
                    var fresh = await Hub.ListSessionsAsync(agent, ct);
                    await InvokeAsync(() => { _sessions = fresh; StateHasChanged(); });
                }
                catch { }
            }, ct);
        }
    }

    private async Task StopStreamingAsync()
    {
        if (_streamCts is not null)
        {
            await _streamCts.CancelAsync();
            _streamCts.Dispose();
            _streamCts = null;
        }
    }

    private void Apply(StreamEvent evt)
    {
        // While ACP is replaying historical session events (between
        // LoadStarted and HistoryDone) AND the chat was already populated
        // from the disk projection (/history?tail=...), drop content
        // events so we don't double-render history on top of the tail
        // snapshot. Control events (LoadStarted/HistoryDone/LoadFailed,
        // TurnComplete, Heartbeat) still flow.
        if (_suppressReplayEvents && evt is AssistantDelta or ThoughtDelta or UserDelta
            or ToolCallStart or ToolCallProgress or ToolCallEnd or ApprovalRequired)
        {
            return;
        }
        switch (evt)
        {
            case AssistantDelta d:
                _thinking = false;
                _streamingThought = null;
                if (_streamingAssistant is null)
                {
                    _streamingAssistant = new ChatMessage { Role = "assistant", Text = "" };
                    _messages.Add(_streamingAssistant);
                }
                _streamingAssistant.Text += d.Text;
                if (d.Text.Length <= 32)
                    Console.WriteLine($"[apply] AssistantDelta gen={_streamGeneration} len={d.Text.Length} text={JsonSerializer.Serialize(d.Text)}");
                else
                    Console.WriteLine($"[apply] AssistantDelta gen={_streamGeneration} len={d.Text.Length}");
                break;
            case ThoughtDelta td:
                _thinking = false;
                if (_streamingThought is null)
                {
                    _streamingThought = new ChatMessage { Role = "thought", Text = "" };
                    _messages.Add(_streamingThought);
                }
                _streamingThought.Text += td.Text;
                break;
            case UserDelta d:
                // Finalize any in-progress assistant message before starting a new turn
                // (during replay, ACP sends user_message_chunk, agent_message_chunk*, user_message_chunk, ...).
                _streamingAssistant = null;
                _streamingThought = null;
                _messages.Add(new ChatMessage { Role = "user", Text = d.Text });
                break;
            case ToolCallStart t:
                _thinking = false;
                _streamingAssistant = null;
                _streamingThought = null;
                // One chip per tool call. The matching ToolCallEnd
                // mutates this same message's ToolStatus in place;
                // the chip animates Pending -> Ok / Fail without
                // leaving a separate "[end] ok" sibling row behind.
                _messages.Add(new ChatMessage
                {
                    Role = "tool",
                    ToolCallId = t.ToolCallId,
                    Text = t.Name,
                    ToolStatus = ToolStatus.Pending,
                });
                break;
            case ToolCallEnd t:
                {
                    var existing = FindToolMessage(t.ToolCallId);
                    if (existing is not null)
                    {
                        existing.ToolStatus = t.Success ? ToolStatus.Ok : ToolStatus.Fail;
                    }
                    else
                    {
                        // No matching ToolCallStart. Shouldn't happen
                        // under normal wire flow but can occur if events
                        // were dropped or this stream is the result of a
                        // mid-turn reconnect. Surface the result as its
                        // own row so the user still sees something.
                        _messages.Add(new ChatMessage
                        {
                            Role = "tool",
                            ToolCallId = t.ToolCallId,
                            Text = "(orphaned tool result)",
                            ToolStatus = t.Success ? ToolStatus.Ok : ToolStatus.Fail,
                        });
                    }
                    break;
                }
            case ApprovalRequired a:
                _thinking = false;
                _pendingApproval = a;
                break;
            case TurnComplete:
                _thinking = false;
                _streamingAssistant = null;
                _streamingThought = null;
                _busy = false;
                break;
            case LoadStarted:
                _loading = true;
                break;
            case HistoryDone:
                _loading = false;
                _suppressReplayEvents = false;
                _streamingAssistant = null;
                _streamingThought = null;
                break;
            case LoadFailed lf:
                _loading = false;
                _suppressReplayEvents = false;
                _messages.Add(new ChatMessage { Role = "tool", Text = $"load failed: {lf.Error}" });
                break;
            case HeartbeatEvent:
                break;
        }
        StateHasChanged();
    }

    private async Task HandleSend(string text)
    {
        if (Agent is null || SessionId is null) return;
        _messages.Add(new ChatMessage { Role = "user", Text = text });
        _busy = true;
        _thinking = true;
        _pendingForceTake = null;
        try
        {
            await Hub.SendPromptAsync(Agent, SessionId, text);
        }
        catch (HostStillOwnedException ex)
        {
            // Polite knock + 60s poll already happened inside the client.
            // Stash the prompt so the user can hit "Take over" to force.
            _busy = false; _thinking = false;
            _pendingForceTake = new PendingForceTake(text, ex.HostPid);
            Snackbar.Add($"Terminal (PID {ex.HostPid}) didn't release. Click 'Take over' to force.", Severity.Warning);
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Role = "tool", Text = $"send failed: {ex.Message}" });
            _busy = false; _thinking = false;
            Snackbar.Add($"Send failed: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    /// <summary>
    /// "Take over from terminal" affordance handler. Bypasses the polite
    /// release-request and force-acquires the session via the agent so
    /// the pending prompt can land. Wraps the call so a force-take
    /// failure surfaces just as cleanly as a polite-send failure.
    /// </summary>
    private async Task HandleForceTake()
    {
        if (Agent is null || SessionId is null || _pendingForceTake is not { } pending) return;
        _busy = true; _thinking = true;
        try
        {
            await Hub.ForceTakeOverAndSendAsync(Agent, SessionId, pending.Text);
            _pendingForceTake = null;
        }
        catch (Exception ex)
        {
            _busy = false; _thinking = false;
            _messages.Add(new ChatMessage { Role = "tool", Text = $"force-take failed: {ex.Message}" });
            Snackbar.Add($"Force take-over failed: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    private void HandleCancelForceTake() { _pendingForceTake = null; StateHasChanged(); }

    /// <summary>
    /// User-driven reconnect from the AppBar pill or the Offline alert.
    /// Resets the attempt counter and re-issues StartStreamingAsync as a
    /// fresh stream (not isReconnect, so the counter starts at 0 and the
    /// status flips back to Connected on the first received event).
    /// Restores the in-memory message snapshot so the user doesn't see
    /// the chat blank for a beat.
    /// </summary>
    private async Task HandleReconnectClick()
    {
        if (Agent is null || SessionId is null) return;
        _streamReconnectAttempts = 0;
        _streamStatus = StreamStatus.Reconnecting;
        _reconnectNextAttemptAt = null;
        var snapshot = _messages
            .Select(m => new ChatMessage
            {
                Role = m.Role,
                Text = m.Text,
                ToolCallId = m.ToolCallId,
                ToolStatus = m.ToolStatus,
            })
            .ToList();
        await StartStreamingAsync(load: false, force: false, restoreFrom: snapshot, isReconnect: true);
    }

    private string StreamStatusTooltip() => _streamStatus switch
    {
        StreamStatus.Connected => "Connected",
        StreamStatus.Reconnecting when _reconnectNextAttemptAt is { } at =>
            $"Reconnecting (next attempt in {Math.Max(0, (int)(at - DateTime.UtcNow).TotalSeconds)}s)...",
        StreamStatus.Reconnecting => "Reconnecting...",
        StreamStatus.Offline => "Connection dropped. Click to retry.",
        _ => "",
    };

    /// <summary>
    /// Demand-load the next older page of history. Invoked by ChatView
    /// when the user scrolls near the top (or clicks the "Load older
    /// messages" button). Preserves the user's visual anchor by
    /// snapshotting scroll position before the prepend and restoring
    /// after.
    /// </summary>
    private async Task HandleLoadOlder()
    {
        if (Agent is null || SessionId is null || !_hasMore || _chatView is null) return;
        var snapshot = await _chatView.SnapshotScrollAsync();
        try
        {
            var page = await Hub.GetHistoryAsync(
                Agent, SessionId,
                before: _oldestCursor, limit: 50);
            if (page is null || page.Entries.Count == 0)
            {
                _hasMore = false;
                return;
            }
            var collapsed = CollapseLegacyToolEntries(page.Entries).ToList();
            for (var i = collapsed.Count - 1; i >= 0; i--)
            {
                var r = collapsed[i];
                _messages.Insert(0, new ChatMessage
                {
                    Role = r.Role,
                    Text = r.Text,
                    ToolCallId = r.ToolCallId,
                    ToolStatus = r.ToolStatus,
                });
            }
            _oldestCursor = page.OldestCursor;
            _hasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            HubLog.LogError($"HandleLoadOlder failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), sessionId: SessionId,
                extra: new { agent = Agent });
        }
        await _chatView.RestoreScrollAfterPrependAsync(snapshot);
    }

    private static string TruncatePreview(string s) =>
        s.Length <= 60 ? s : s[..57] + "...";

    private async Task HandleApproval((string ApprovalId, string OptionId) a)
    {
        if (Agent is null || SessionId is null || _pendingApproval is null) return;
        await Hub.ResolveApprovalAsync(Agent, SessionId, a.ApprovalId, a.OptionId);
        _pendingApproval = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        SnapshotCurrentMessages();
        await StopStreamingAsync();
    }
}
