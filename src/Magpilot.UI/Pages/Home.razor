@page "/"
@page "/agents/{agent}"
@page "/agents/{agent}/sessions/{sessionId}"
@inject HubClient Hub
@inject HubLogClient HubLog
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Home> Log
@implements IAsyncDisposable
@using System.Collections.ObjectModel
@using System.Text.Json
@using Magpilot.UI.Services
@using Microsoft.Extensions.Logging

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudHidden Breakpoint="Breakpoint.LgAndUp">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="@ToggleDrawer"
                           aria-label="Toggle navigation" />
        </MudHidden>
        <MudText Typo="Typo.h6" Class="ml-1 mr-4">Magpilot</MudText>
        @if (Agent is not null)
        {
            @* The host pill always shows in the AppBar -- it's the
               authoritative live-status indicator (green dot when
               connected, amber spinner when reconnecting, red
               CloudOff when offline). Even when the drawer is open
               in wide view (which has its own host name in the
               sessions header), the AppBar pill stays visible so the
               status is always at-a-glance reachable from the top
               chrome.

               The pill renders as a transparent-fill outlined chip
               whose border colour matches the dot/spinner/icon, so
               state transitions read both from the inline glyph and
               from the surrounding border. *@
            <HostName Agent="@Agent"
                      Online="@(_agents?.FirstOrDefault(a => a.Name == Agent)?.Online)"
                      Color="@AppBarHostColor()"
                      StatusText="@AppBarHostStatusText()"
                      Indeterminate="@(SessionId is not null && _streamStatus == StreamStatus.Reconnecting)"
                      Outlined="true" />
            @if (_currentSessionTitle is not null)
            {
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="mx-1" />
                <MudText Typo="Typo.body2" Class="text-truncate" Style="max-width: 40vw;"
                         title="@_currentSessionTitle">@_currentSessionTitle</MudText>
            }
        }
        <MudSpacer />
        <MudTooltip Text="View central logs">
            <MudIconButton Icon="@Icons.Material.Filled.Article"
                           Color="Color.Inherit"
                           Href="/admin/logs"
                           aria-label="Logs" />
        </MudTooltip>
        <MudTooltip Text="@((Theme?.IsDark ?? false) ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@((Theme?.IsDark ?? false) ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@OnToggleDarkMode" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Lg"
               Elevation="1"
               Color="Color.Surface">
        @if (Agent is null || _showHostsPane)
        {
            @* Hosts pane: pick a host. Hub icon sits in the same column as the *@
            @* host-row radio bullets so the leading edges line up vertically.   *@
            <div class="d-flex align-center gap-2 px-4 py-3">
                <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Small" />
                <MudText Typo="Typo.subtitle1">Hosts</MudText>
            </div>

            @if (_agents is null)
            {
                <MudList T="string" Dense="true">
                    @for (var i = 0; i < 3; i++)
                    {
                        <MudListItem T="string" Disabled="true">
                            <MudSkeleton Width="80%" Height="20px" />
                        </MudListItem>
                    }
                </MudList>
            }
            else if (_agents.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mx-3 my-2">
                    No hosts discovered yet.
                </MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true" SelectedValue="@Agent" SelectedValueChanged="@OnAgentSelected">
                    @foreach (var a in _agents)
                    {
                        <MudListItem T="string" Value="@a.Name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@(a.Online ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                                         Color="@(a.Online ? Color.Success : Color.Default)"
                                         Size="Size.Small" />
                                <MudText Typo="Typo.body1">@a.Name</MudText>
                                @if (a.Flavors is { Count: > 0 } flavors && flavors.Any(f => f != "default"))
                                {
                                    <MudSpacer />
                                    @foreach (var f in flavors.Where(f => f != "default"))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">@f</MudChip>
                                    }
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }

            @if (Agent is not null && _showHostsPane)
            {
                @* Reassurance affordance: an explicit way back to the active   *@
                @* host's sessions, so the user isn't trapped if they bounced  *@
                @* into the hosts pane just to glance at the host list.        *@
                <MudDivider Class="my-2" />
                <div class="px-3 pb-3">
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="@(() => _showHostsPane = false)">
                        Back to @Agent
                    </MudButton>
                </div>
            }
        }
        else
        {
            @* Sessions pane: focused on a single host. Back arrow returns to *@
            @* the hosts pane (without leaving the open chat).                *@
            <div class="d-flex align-center gap-1 px-2 py-2"
                 style="border-bottom: 1px solid var(--mud-palette-divider);">
                <MudTooltip Text="Back to hosts">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Size="Size.Small"
                                   OnClick="@GoBackToHosts"
                                   aria-label="Back to hosts" />
                </MudTooltip>
                @* Drawer header just identifies the host by name; the
                   AppBar pill (always visible above) is the live
                   stream-status indicator, so we don't double up the
                   dot/spinner/icon glyph here. *@
                <MudText Typo="Typo.subtitle1" Class="ml-1 text-truncate"
                         Style="min-width: 0;" title="@Agent">@Agent</MudText>
                <MudSpacer />
                <MudTooltip Text="Refresh session list">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   OnClick="@RefreshSessions"
                                   Disabled="@_sessionsRefreshing"
                                   aria-label="Refresh session list" />
                </MudTooltip>
                @if (PastSessionCount > 0)
                {
                    <MudTooltip Text="@($"Resume a previous session ({PastSessionCount})")">
                        <MudIconButton Icon="@Icons.Material.Filled.History"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="@OpenResumePanel"
                                       aria-label="Resume a previous session" />
                    </MudTooltip>
                }
                <MudTooltip Text="New chat">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@OpenNewSessionDialog"
                                   aria-label="New chat" />
                </MudTooltip>
            </div>

            @* Indeterminate progress bar across the full pane width
               whenever a session-list fetch is in flight: either the
               initial load on agent switch (_sessions is null and we
               have an Agent + no route error) or an explicit user-
               triggered Refresh. Mirrors the Logs.razor loading-bar
               pattern so feedback is consistent across the SPA. *@
            @if (_sessionsRefreshing || (_sessions is null && Agent is not null && _routeError is null))
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            }

            @if (_sessions is null)
            {
                <MudList T="string" Dense="true">
                    @for (var i = 0; i < 4; i++)
                    {
                        <MudListItem T="string" Disabled="true">
                            <MudSkeleton Width="90%" Height="20px" />
                            <MudSkeleton Width="50%" Height="14px" />
                        </MudListItem>
                    }
                </MudList>
            }
            else if (_sessions.Count == 0)
            {
                <MudPaper Class="mx-3 my-3 pa-3 d-flex flex-column align-center" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Class="my-2" Color="Color.Default">No sessions on @Agent yet</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenNewSessionDialog">
                        Start one
                    </MudButton>
                </MudPaper>
            }
            else
            {
                @* Flat list of currently-loadable sessions: Active first
                   (you own it), then Locked (held by another process).
                   Each row prefixes a small state icon so the user can
                   tell at a glance which is which without needing a
                   group header. Past sessions live in the resume-
                   previous dialog (history icon in the toolbar above). *@
                <MudList T="string" Dense="true" SelectedValue="@SessionId" SelectedValueChanged="@OnSessionSelected">
                    @foreach (var s in ActiveAndLockedSessions(_sessions))
                    {
                        var (stateColor, stateIcon) = GroupVisuals(s.State);
                        var stateTooltip = s.State switch
                        {
                            SessionState.Owned  => "Active -- this hub owns the session",
                            SessionState.Locked => "Locked -- held by another process; opening will adopt it",
                            _                   => s.State.ToString(),
                        };
                        var folderLabel = !string.IsNullOrWhiteSpace(s.Cwd)
                            ? ShortPath(s.Cwd)
                            : (!string.IsNullOrWhiteSpace(s.Repository) ? DisplayRepo(s.Repository) : null);
                        var folderTooltip = !string.IsNullOrWhiteSpace(s.Cwd) ? s.Cwd : s.Repository;

                        <MudListItem T="string" Value="@s.Id" Class="py-2">
                            <MudStack Spacing="0" Style="min-width: 0;">
                                @* All three rows (title / folder / branch)
                                   use the same 1.25rem icon slot + 2-unit
                                   gap so the icons centre on a shared left
                                   column and the text on every row starts
                                   at the same x. The state icon stays at
                                   Size.Small (1.25rem, fills the slot)
                                   while folder / branch icons render at
                                   1rem and centre inside the same slot,
                                   so the bigger title-row icon doesn't
                                   shift the column. *@
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                    @* Native title attribute on the slot
                                       (rather than MudTooltip) avoids the
                                       inline-block tooltip wrapper that
                                       picks up the surrounding line-height
                                       and pushes the icon ~2px above the
                                       title text's vertical centre.

                                       Owned (active) sessions render the
                                       magpie brand mark instead of the
                                       generic green dot -- the dot is now
                                       reserved for "system online" status
                                       in the AppBar, so reusing it here
                                       was conflating two unrelated states.
                                       Locked + Dormant keep their
                                       Material glyphs since they convey
                                       generic states the brand mark
                                       wouldn't read as. *@
                                    <span class="d-inline-flex align-center justify-center"
                                          style="width: 1.25rem; height: 1.25rem; flex-shrink: 0;"
                                          title="@stateTooltip">
                                        @if (s.State == SessionState.Owned)
                                        {
                                            @* Render the magpie larger than
                                               the surrounding 1.25rem icon
                                               slot so the visible bird (which
                                               only fills ~70% of the SVG's
                                               square canvas due to internal
                                               padding) reads at roughly the
                                               same size as the Locked padlock
                                               and the folder/branch glyphs.
                                               flex-shrink: 0 on the slot
                                               keeps the row layout anchored
                                               at 1.25rem; the img just
                                               overflows visually into the
                                               surrounding row whitespace. *@
                                            <MagpieMark Size="28" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@stateIcon" Color="@stateColor" Size="Size.Small" />
                                        }
                                    </span>
                                    <MudText Typo="Typo.body1" Class="text-truncate"
                                             Style="font-weight: 500; min-width: 0; flex: 1;"
                                             title="@(s.Summary ?? s.Id)">
                                        @(s.Summary ?? s.Id[..8])
                                    </MudText>
                                    @if (s.Yolo)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                 Color="Color.Warning" Icon="@Icons.Material.Filled.Bolt"
                                                 Class="flex-shrink-0">
                                            YOLO
                                        </MudChip>
                                    }
                                    @if (s.UpdatedAt is { } ua)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Default"
                                                 Style="white-space: nowrap; flex-shrink: 0;">@RelativeTime(ua)</MudText>
                                    }
                                </MudStack>
                                @* Folder + branch rows always render so every
                                   list item is the same height regardless of
                                   whether a session has a working dir or
                                   git branch. The 1.25rem icon slot enforces
                                   the row's vertical extent; the icon + text
                                   inside are skipped when there's nothing
                                   to show, leaving an empty placeholder
                                   that keeps the rows visually flush. *@
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                    <span class="d-inline-flex align-center justify-center"
                                          style="width: 1.25rem; height: 1.25rem; flex-shrink: 0;">
                                        @if (!string.IsNullOrWhiteSpace(folderLabel))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen"
                                                     Style="font-size: 1rem !important;"
                                                     Color="Color.Default" />
                                        }
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(folderLabel))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Default" Class="text-truncate"
                                                 Style="min-width: 0;" title="@folderTooltip">
                                            @folderLabel
                                        </MudText>
                                    }
                                </MudStack>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                    <span class="d-inline-flex align-center justify-center"
                                          style="width: 1.25rem; height: 1.25rem; flex-shrink: 0;">
                                        @if (!string.IsNullOrWhiteSpace(s.Branch))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CallSplit"
                                                     Style="font-size: 1rem !important;"
                                                     Color="Color.Default" />
                                        }
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(s.Branch))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Default" Class="text-truncate"
                                                 Style="min-width: 0;" title="@s.Branch">
                                            @s.Branch
                                        </MudText>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        }
    </MudDrawer>

    <MudMainContent Class="d-flex flex-column" Style="height: 100dvh; overflow: hidden;">
        @if (_newSessionOpen)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudText Typo="Typo.h5" Class="mb-2">New chat on @Agent</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
                        Pick a working directory for the conversation. Leave blank to use the agent's default.
                    </MudText>
                    <MudAutocomplete T="string" Label="Working directory"
                                     @bind-Value="_newSessionCwd"
                                     SearchFunc="@SearchCwds"
                                     Variant="Variant.Outlined"
                                     CoerceValue="true"
                                     ResetValueOnEmptyText="false"
                                     Placeholder="(leave blank for agent default)"
                                     Class="mb-4" />
                    @if (_currentAgentSupportsAgency)
                    {
                        <MudCheckBox T="bool" @bind-Value="_newSessionUseAgency" Color="Color.Primary"
                                     Label="Wrap with agency (extra MCP servers)"
                                     Class="mb-4" />
                    }
                    @if (_newSessionError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_newSessionError</MudAlert>
                    }
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" Disabled="@_newSessionBusy" OnClick="@CancelNewSession">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="@_newSessionBusy"
                                   OnClick="@ConfirmNewSession"
                                   StartIcon="@(_newSessionBusy ? null : Icons.Material.Filled.Send)">
                            @if (_newSessionBusy)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Creating...</span>
                            }
                            else
                            {
                                <span>Create</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (_resumePanelOpen)
        {
            @* Resume-previous panel: opened from the sessions-pane history
               icon. Replaces the old always-visible "Past" group in the
               drawer so a host with hundreds of historical chats doesn't
               push Active + Locked out of view. Mirrors the inline
               new-chat panel layout below so the two affordances feel
               consistent -- both take over the chat surface instead of
               floating as overlays. Cancel returns the user to whatever
               was on screen before (chat or no-session welcome). *@
            <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
                <MudPaper Class="pa-6 d-flex flex-column" Elevation="2" Style="max-height: calc(100dvh - 8rem);">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.History" />
                        <MudText Typo="Typo.h5">Resume previous session on @Agent</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
                        Search past conversations by summary, repository, working directory, or session id.
                    </MudText>
                    <MudTextField T="string"
                                  Value="@_resumeSearch"
                                  ValueChanged="@OnResumeSearchChanged"
                                  Placeholder="Search by name, repo, or directory..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  DebounceInterval="150"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  Class="mb-3" />
                    @{
                        var pastFiltered = FilteredPastSessions();
                    }
                    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-2 d-block">
                        @if (string.IsNullOrWhiteSpace(_resumeSearch))
                        {
                            <text>@pastFiltered.Count of @PastSessionCount past session@(PastSessionCount == 1 ? "" : "s")</text>
                        }
                        else
                        {
                            <text>@pastFiltered.Count match@(pastFiltered.Count == 1 ? "" : "es")</text>
                        }
                    </MudText>
                    <MudPaper Elevation="0" Outlined="true" Class="flex-grow-1 mb-4" Style="overflow-y: auto; min-height: 0;">
                        @if (pastFiltered.Count == 0)
                        {
                            <div class="pa-6 d-flex flex-column align-center">
                                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
                                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-2">No matches</MudText>
                            </div>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var s in pastFiltered)
                                {
                                    var folderLabel = !string.IsNullOrWhiteSpace(s.Cwd)
                                        ? ShortPath(s.Cwd)
                                        : (!string.IsNullOrWhiteSpace(s.Repository) ? DisplayRepo(s.Repository) : null);
                                    var folderTooltip = !string.IsNullOrWhiteSpace(s.Cwd) ? s.Cwd : s.Repository;

                                    <MudListItem T="string" Value="@s.Id" Class="py-2"
                                                 OnClick="@(() => OnResumePick(s.Id))">
                                        <MudStack Spacing="0" Style="min-width: 0;">
                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                                <MudText Typo="Typo.body1" Class="text-truncate"
                                                         Style="font-weight: 500; min-width: 0; flex: 1;"
                                                         title="@(s.Summary ?? s.Id)">
                                                    @(s.Summary ?? s.Id[..8])
                                                </MudText>
                                                @if (s.UpdatedAt is { } ua)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Default"
                                                             Style="white-space: nowrap; flex-shrink: 0;">@RelativeTime(ua)</MudText>
                                                }
                                            </MudStack>
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                                <span class="d-inline-flex align-center justify-center"
                                                      style="width: 1.25rem; height: 1.25rem; flex-shrink: 0;">
                                                    @if (!string.IsNullOrWhiteSpace(folderLabel))
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.FolderOpen"
                                                                 Style="font-size: 1rem !important;"
                                                                 Color="Color.Default" />
                                                    }
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(folderLabel))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Default" Class="text-truncate"
                                                             Style="min-width: 0;" title="@folderTooltip">
                                                        @folderLabel
                                                    </MudText>
                                                }
                                            </MudStack>
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Style="min-width: 0;">
                                                <span class="d-inline-flex align-center justify-center"
                                                      style="width: 1.25rem; height: 1.25rem; flex-shrink: 0;">
                                                    @if (!string.IsNullOrWhiteSpace(s.Branch))
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.CallSplit"
                                                                 Style="font-size: 1rem !important;"
                                                                 Color="Color.Default" />
                                                    }
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(s.Branch))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Default" Class="text-truncate"
                                                             Style="min-width: 0;" title="@s.Branch">
                                                        @s.Branch
                                                    </MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" OnClick="@CancelResumePanel">Cancel</MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (_pendingOrphan is not null)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
                <MudPaper Class="pa-6" Elevation="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                        <MudText Typo="Typo.h6">Adopt running session?</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Class="mb-2">
                        This session is held by another process (PID <strong>@_pendingOrphan.OwnerPid</strong>).
                        Adopting will <em>kill</em> that process and load the session under magpilot.
                    </MudText>
                    <MudPaper Class="pa-3 my-3" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.caption" Color="Color.Default">@(_pendingOrphan.Summary ?? _pendingOrphan.Id)</MudText>
                    </MudPaper>
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text" OnClick="@CancelOrphanAdopt">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                                   OnClick="@ConfirmOrphanAdopt">
                            Kill PID @_pendingOrphan.OwnerPid and adopt
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (_routeError is not null)
        {
            var (icon, color, title, body) = _routeError switch
            {
                "agent-unknown" => (
                    Icons.Material.Filled.HelpOutline,
                    Color.Warning,
                    $"Host '{Agent}' is unknown",
                    "This host isn't registered with the hub. Pick one from the drawer, or check that the host's magpilot agent is running and discoverable on the LAN."),
                "agent-offline" => (
                    Icons.Material.Filled.CloudOff,
                    Color.Error,
                    $"Host '{Agent}' is unreachable",
                    "The hub couldn't reach this host. The agent may be stopped, the machine off, or the LAN connection down. Try again once it's back."),
                "session-not-found" => (
                    Icons.Material.Filled.SearchOff,
                    Color.Warning,
                    "Session not found",
                    $"No session with id '{SessionId}' exists on '{Agent}'. It may have been deleted, or the link is stale."),
                _ => (Icons.Material.Filled.ErrorOutline, Color.Error, "Something went wrong",
                      "Pick another session from the drawer or go back to the host list.")
            };
            <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
                <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="2">
                    <MudIcon Icon="@icon" Color="@color" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.h6" Class="mb-2">@title</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Default" Align="Align.Center" Class="mb-4">
                        @body
                    </MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   Disabled="@_routeRetryBusy"
                                   OnClick="@HandleRouteRetry">
                            Try again
                        </MudButton>
                        @if (Agent is not null && _routeError == "session-not-found")
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       OnClick="@(() => Nav.NavigateTo($"/agents/{Agent}"))">
                                Back to @Agent
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Text" Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Home"
                                   OnClick="@(() => Nav.NavigateTo("/"))">
                            All hosts
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudContainer>
        }
        else if (Agent is not null && SessionId is not null)
        {
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            }
            <div class="chat-toolbar-mud px-3 py-1 d-flex align-center">
                <MudSwitch T="bool" Color="Color.Primary" Size="Size.Small"
                           Value="_showThoughts" ValueChanged="@SetShowThoughts"
                           Label="Show thinking" />
                @{
                    var yoloDisabledOnHost = _yoloDisabledHosts.Contains(Agent ?? "");
                    var currentYolo = _sessions?.FirstOrDefault(s => s.Id == SessionId)?.Yolo == true;
                }
                <MudTooltip Text="@(yoloDisabledOnHost ? "Yolo mode is disabled on this host" : "Auto-approve each tool call for this session. Flips off any time to restore manual approval for new permissions.")"
                            Placement="Placement.Bottom">
                    <MudSwitch T="bool" Color="Color.Warning" Size="Size.Small"
                               Value="@currentYolo" ValueChanged="@SetYoloForCurrentSession"
                               Disabled="@(yoloDisabledOnHost || _yoloBusy)"
                               Label="YOLO" Class="ml-3" />
                </MudTooltip>
                <MudSpacer />
                <MudTooltip Text="Release this session. Drops the agent's ACP copy back to Dormant; reopening adopts it again. Use this to free the agent's slot or before driving the session from a terminal."
                            Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Size="Size.Small"
                                   Color="Color.Default"
                                   Disabled="@_releaseBusy"
                                   OnClick="ReleaseCurrentSession"
                                   aria-label="Release session" />
                </MudTooltip>
            </div>
            @if (_streamStatus == StreamStatus.Offline)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mx-3 my-2"
                          ContentAlignment="HorizontalAlignment.Left">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">
                            Connection to the agent dropped and didn't recover.
                        </MudText>
                        <MudSpacer />
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="HandleReconnectClick">
                            Reconnect
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            @if (_pendingForceTake is { } pending)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mx-3 my-2"
                          ContentAlignment="HorizontalAlignment.Left">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body2">
                            Terminal session (PID @pending.HostPid) didn't release for "@TruncatePreview(pending.Text)".
                        </MudText>
                        <MudSpacer />
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                                   OnClick="HandleForceTake">
                            Take over from terminal
                        </MudButton>
                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Close"
                                       OnClick="HandleCancelForceTake" aria-label="Dismiss" />
                    </MudStack>
                </MudAlert>
            }
            <ChatView @ref="_chatView"
                      Messages="@_messages"
                      PendingApproval="@_pendingApproval"
                      Disabled="@_loading"
                      Busy="@_busy"
                      Thinking="@_thinking"
                      ShowThoughts="@_showThoughts"
                      HasMore="@_hasMore"
                      OnLoadMore="HandleLoadOlder"
                      OnSend="HandleSend"
                      OnCancel="HandleCancel"
                      QueuedMessages="@_queuedMessages"
                      OnDeleteQueued="HandleDeleteQueued"
                      DraftText="@_currentDraft"
                      SessionKey="@_streamingFor"
                      OnDraftChanged="HandleDraftChanged"
                      OnApproval="HandleApproval" />
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="flex: 1;">
                <MagpieMark Size="96" Glow="true" />
                <MudText Typo="Typo.h4" Class="mt-3 mb-2">Magpilot</MudText>
                <MudText Typo="Typo.body1" Color="Color.Default" Align="Align.Center">
                    Pick a host on the left to see its sessions, or start a new chat.
                </MudText>
            </MudContainer>
        }
    </MudMainContent>
</MudLayout>

@code {
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [Parameter] public string? Agent { get; set; }
    [Parameter] public string? SessionId { get; set; }

    [CascadingParameter] public ThemeState? Theme { get; set; }

    private async Task OnToggleDarkMode()
    {
        if (Theme is null) return;
        await Theme.Set.InvokeAsync(!Theme.IsDark);
    }

    private List<AgentInfo>? _agents;
    private List<SessionInfo>? _sessions;
    private bool _drawerOpen = true;
    private bool _showHostsPane;
    private bool _sessionsRefreshing;
    private readonly ObservableCollection<ChatMessage> _messages = new();
    private ChatMessage? _streamingAssistant;
    private ChatMessage? _streamingThought;
    /// <summary>
    /// Last <see cref="ThoughtDelta"/> text appended to
    /// <see cref="_streamingThought"/>. Used by Apply() to dedupe
    /// consecutive identical thought chunks (see ThoughtDelta case).
    /// Cleared every time a new thought bubble starts.
    /// </summary>
    private string? _lastThoughtChunkText;
    private ApprovalRequired? _pendingApproval;
    private CancellationTokenSource? _streamCts;
    private bool _busy;
    private bool _loading;
    /// <summary>
    /// Messages the user typed and sent while a turn was still in
    /// flight. They get drained FIFO each time the agent emits a
    /// TurnComplete. The user can delete individual entries before
    /// they fire via the queue chips above the composer.
    /// </summary>
    private readonly List<string> _queuedMessages = new();
    /// <summary>
    /// Half-typed message in the composer for the currently-open
    /// session. Mirrored to ChatView via its <c>DraftText</c> parameter
    /// and written back here through <c>OnDraftChanged</c> on every
    /// keystroke + after a successful send. Cached per-session in
    /// <see cref="_draftCache"/> AND persisted to localStorage under
    /// <see cref="DraftStorageKey"/>, so switching away then back, or
    /// a full page refresh, both restore the user's in-progress text.
    /// </summary>
    private string _currentDraft = "";
    /// <summary>
    /// Per-session draft cache, keyed the same way as <see cref="_msgCache"/>
    /// (<c>{agent}/{sid}</c>). Mirrors what's also written to
    /// localStorage; the in-memory cache is the fast path for
    /// session-to-session switching without round-tripping JS.
    /// </summary>
    private readonly Dictionary<string, string> _draftCache = new();
    /// <summary>
    /// Per-session queue cache, keyed the same way as the draft + msg
    /// caches. localStorage is the durable copy; this is the
    /// session-switch-fast-path.
    /// </summary>
    private readonly Dictionary<string, List<string>> _queueCache = new();
    private const string DraftStorageKeyPrefix = "magpilot.draft.";
    private const string QueueStorageKeyPrefix = "magpilot.queue.";
    private static string DraftStorageKey(string sessionKey) => $"{DraftStorageKeyPrefix}{sessionKey}";
    private static string QueueStorageKey(string sessionKey) => $"{QueueStorageKeyPrefix}{sessionKey}";
    /// <summary>
    /// When true, content events (user/assistant/thought/tool/approval)
    /// arriving on the stream between LoadStarted and HistoryDone are
    /// dropped instead of appended to <see cref="_messages"/>. Set by
    /// <see cref="StartStreamingAsync"/> whenever the caller is loading
    /// the session into ACP (<c>load: true</c>) but has already populated
    /// the visible chat from <c>restoreFrom</c> (i.e. the paged
    /// /history?tail=50 disk projection). Without this, opening a large
    /// Dormant session re-streams every historical event on top of the
    /// tail snapshot -- doubling the chat AND defeating the whole
    /// point of paging.
    /// </summary>
    private bool _suppressReplayEvents;
    private bool _thinking;
    // Debounced re-arm of the "thinking" dots between segments of one turn.
    // Copilot CLI's built-in tools (bash/read/write) run without emitting any
    // SSE events, so after an assistant segment finishes a turn can sit silent
    // for tens of seconds while _busy stays true -- the chat's last row is a
    // completed bubble and looks idle even though work is ongoing. Each content
    // event hides the dots and arms this timer; if the lull outlasts the window
    // the dots reappear as a "still working" cue. The debounce keeps them from
    // flickering between the many small deltas of an actively-streaming message.
    private const int ThinkingDebounceMs = 800;
    private CancellationTokenSource? _thinkingDebounceCts;
    // Paging cursor for the demand-load-older flow (see HandleLoadOlder).
    // _oldestCursor is the ordinal id of the oldest entry currently in
    // _messages; pass back as ?before= on the next history call. Reset
    // (along with _hasMore) when the session changes -- see StartStreamingAsync.
    private int _oldestCursor;
    private bool _hasMore;
    private ChatView? _chatView;
    /// <summary>
    /// When the agent refuses a prompt because a magpilot launcher holds
    /// the session AND the wrapper failed to release within the polite-knock
    /// window, we stash the user's prompt here so they can hit "Take over
    /// from terminal" to force-acquire and retry. Cleared on success or
    /// explicit cancel.
    /// </summary>
    private PendingForceTake? _pendingForceTake;
    private string? _streamingFor;
    private int _streamGeneration;
    // Number of consecutive auto-reconnect attempts since the last successful
    // event. Reset to 0 whenever the stream pump receives any payload, or when
    // the user navigates to a different session. Capped to avoid infinite
    // reconnect loops if the agent is genuinely down.
    private int _streamReconnectAttempts;
    /// <summary>
    /// User-visible connection state for the currently-open session's SSE
    /// stream. Drives the AppBar status pill + the "give up" alert.
    /// Connected = any event received in the last reconnect cycle.
    /// Reconnecting = stream dropped, exponential backoff in progress.
    /// Offline = exhausted maxAttempts reconnect tries, user action required.
    /// </summary>
    private enum StreamStatus { Connected, Reconnecting, Offline }
    private StreamStatus _streamStatus = StreamStatus.Connected;
    /// <summary>
    /// Next retry timestamp during Reconnecting. Used to render a
    /// countdown in the status pill tooltip. Null when not reconnecting.
    /// </summary>
    private DateTime? _reconnectNextAttemptAt;
    private SessionInfo? _pendingOrphan;
    private bool _newSessionOpen;
    private string _newSessionCwd = "";
    private bool _newSessionUseAgency;
    private string? _newSessionError;
    private bool _newSessionBusy;
    private List<string> _cwdSuggestions = new();

    // Resume-previous panel state. The panel is opened from the
    // sessions-pane header (history icon) and renders inline in
    // MudMainContent (matching the new-chat flow) so it doesn't
    // disrupt the user as a floating overlay. _resumeSearch is bound
    // to a debounced MudTextField; FilteredPastSessions reads it on
    // each render.
    private bool _resumePanelOpen;
    private string _resumeSearch = "";

    /// <summary>
    /// GitHub login of the currently signed-in user (from
    /// <c>GET /api/me</c>), or null if anonymous / lookup failed.
    /// Drives <see cref="DisplayRepo"/>: a repo whose name starts
    /// with <c>{identity}/</c> is shown as just the trailing repo
    /// name. The full <c>owner/repo</c> still goes into the
    /// session-list chip's tooltip so the original is one hover away.
    /// </summary>
    private string? _currentUserIdentity;

    /// <summary>
    /// Render-time helper: shorten <c>owner/repo</c> to <c>repo</c>
    /// when <c>owner</c> matches the signed-in user. Generic --
    /// returns the input unchanged for repos owned by anyone else,
    /// or when the identity is unknown (anonymous / dev runs without
    /// OAUTH_ALLOWED_GITHUB_USERS set).
    /// </summary>
    private string DisplayRepo(string? repo)
    {
        if (string.IsNullOrEmpty(repo) || string.IsNullOrEmpty(_currentUserIdentity))
            return repo ?? string.Empty;
        var prefix = _currentUserIdentity + "/";
        return repo.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            ? repo[prefix.Length..]
            : repo;
    }

    // Route-validation state set by OnParametersSetAsync. When non-null
    // the chat view is replaced by a NotFound alert and the streaming
    // pipeline is skipped entirely. Values:
    //   "agent-unknown"     -- Agent is set but not in _agents.
    //   "agent-offline"     -- ListSessionsAsync threw for this Agent.
    //   "session-not-found" -- SessionId not in _sessions (after a
    //                          successful list fetch).
    // Cleared at the top of OnParametersSetAsync so a fix-and-retry
    // navigation works.
    private string? _routeError;
    private bool _sessionsListFailed;
    private bool _routeRetryBusy;

    // Last Agent value we successfully fetched _sessions for. Tracked so
    // OnParametersSetAsync can drop stale data on a real agent switch
    // without clobbering the list every time we re-enter the lifecycle
    // for an unrelated parameter change (e.g. SessionId navigation
    // within the same agent).
    private string? _lastLoadedAgent;

    private sealed record PendingForceTake(string Text, int HostPid);

    // Per-session in-memory snapshot of messages, keyed by "{Agent}/{SessionId}".
    // We keep this so switching back to an Owned session restores its
    // chat history without re-issuing session/load (ACP rejects double-load
    // with -32602 "already loaded"). Snapshots are written when leaving a
    // session and refreshed on every Apply() while viewing it.
    private readonly Dictionary<string, List<ChatMessage>> _msgCache = new();
    private bool _showThoughts = true;
    private const string ShowThoughtsKey = "magpilot.showThoughts";

    protected override async Task OnInitializedAsync()
    {
        try { _agents = await Hub.ListAgentsAsync(); }
        catch (Exception ex)
        {
            _agents = [];
            HubLog.LogError($"ListAgentsAsync failed: {ex.Message}", ex.ToString(), category: nameof(Home));
            Snackbar.Add($"Could not load hosts: {ex.Message}", Severity.Error);
        }

        // Used by DisplayRepo() to strip "{identity}/" from repo
        // names when they belong to the signed-in user. Anonymous if
        // /api/me fails -- repo names just render with their owner
        // prefix, which is the pre-strip behaviour.
        try
        {
            var me = await Hub.GetMeAsync();
            _currentUserIdentity = me?.Identity;
        }
        catch (Exception ex)
        {
            HubLog.LogError($"GetMeAsync failed: {ex.Message}", ex.ToString(), category: nameof(Home));
        }

        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ShowThoughtsKey);
            if (stored is not null) _showThoughts = stored == "true";
        }
        catch { }
    }

    private async Task ToggleShowThoughts(ChangeEventArgs e)
    {
        _showThoughts = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var p) && p;
        try { await JS.InvokeVoidAsync("localStorage.setItem", ShowThoughtsKey, _showThoughts ? "true" : "false"); }
        catch { }
    }

    private async Task SetShowThoughts(bool value)
    {
        _showThoughts = value;
        try { await JS.InvokeVoidAsync("localStorage.setItem", ShowThoughtsKey, value ? "true" : "false"); }
        catch { }
    }

    // Hosts that have answered 403 to a yolo flip (MAGPILOT_YOLO_DISABLED=true).
    // Sticky for the lifetime of the SPA so we don't grey -> retry -> grey on
    // every keystroke. Cleared on full page reload, which is fine -- changing
    // the env var requires an agent restart anyway.
    private readonly HashSet<string> _yoloDisabledHosts = new(StringComparer.OrdinalIgnoreCase);
    private bool _yoloBusy;

    private async Task SetYoloForCurrentSession(bool value)
    {
        if (string.IsNullOrEmpty(Agent) || string.IsNullOrEmpty(SessionId) || _sessions is null)
            return;
        if (_yoloDisabledHosts.Contains(Agent)) return;

        _yoloBusy = true;
        try
        {
            var state = await Hub.SetYoloAsync(Agent, SessionId, value);
            // Mirror the new yolo bit into the local _sessions list so the
            // toolbar switch + the per-row YOLO pill update without a
            // separate refresh round-trip.
            var idx = _sessions.FindIndex(s => s.Id == SessionId);
            if (idx >= 0)
                _sessions[idx] = _sessions[idx] with { Yolo = state.Info.Yolo };
            Snackbar.Add(value ? "Yolo on -- auto-approving for this session" : "Yolo off",
                value ? Severity.Warning : Severity.Info);
        }
        catch (YoloDisabledException)
        {
            _yoloDisabledHosts.Add(Agent);
            Snackbar.Add("Yolo mode is disabled on this host (MAGPILOT_YOLO_DISABLED=true).", Severity.Error);
        }
        catch (Exception ex)
        {
            HubLog.LogError($"SetYoloAsync failed: {ex.Message}", ex.ToString(), category: nameof(Home),
                sessionId: SessionId,
                extra: new { agent = Agent, enabled = value });
            Snackbar.Add($"Could not change yolo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _yoloBusy = false;
        }
    }

    private bool _releaseBusy;

    /// <summary>
    /// "Try again" from the route-error alert. Re-fetches the host
    /// list (in case a previously-unknown agent just came online via
    /// discovery, or a previously-offline host is back) and then
    /// re-runs OnParametersSetAsync's route validation so a successful
    /// fetch transitions the page out of the error state.
    /// </summary>
    private async Task HandleRouteRetry()
    {
        _routeRetryBusy = true;
        try
        {
            try { _agents = await Hub.ListAgentsAsync(); }
            catch (Exception ex)
            {
                HubLog.LogError($"ListAgentsAsync (retry) failed: {ex.Message}", ex.ToString(),
                    category: nameof(Home));
                Snackbar.Add($"Could not refresh hosts: {ex.Message}", Severity.Error);
            }
            await OnParametersSetAsync();
        }
        finally
        {
            _routeRetryBusy = false;
        }
    }

    /// <summary>
    /// Drop the agent's ACP copy of the current session back to Dormant
    /// and navigate to the agent's session-list view. The session
    /// remains on disk -- reopening it triggers an adopt+load, picking
    /// up any events appended in the meantime.
    /// </summary>
    private async Task ReleaseCurrentSession()
    {
        if (string.IsNullOrEmpty(Agent) || string.IsNullOrEmpty(SessionId))
            return;

        // Snapshot the values; navigation below clears them.
        var agent = Agent;
        var sessionId = SessionId;

        _releaseBusy = true;
        try
        {
            await Hub.DetachAsync(agent, sessionId);

            // Refresh the session list so the row immediately reflects the
            // new Dormant state -- otherwise an immediate re-entry would
            // route through the "Owned + cache present" branch and skip
            // the necessary session/load.
            try { _sessions = await Hub.ListSessionsAsync(agent); }
            catch (Exception listEx)
            {
                HubLog.LogWarning($"ListSessionsAsync after detach failed: {listEx.Message}",
                    category: nameof(Home), sessionId: sessionId,
                    extra: new { agent });
            }

            Snackbar.Add("Session released. Reopening it will re-load it on the agent.", Severity.Info);
            Nav.NavigateTo($"/agents/{agent}");
        }
        catch (Exception ex)
        {
            HubLog.LogError($"DetachAsync failed: {ex.Message}", ex.ToString(), category: nameof(Home),
                sessionId: sessionId, extra: new { agent });
            Snackbar.Add($"Could not release session: {ex.Message}", Severity.Error);
        }
        finally
        {
            _releaseBusy = false;
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnAgentSelected(string? name)
    {
        _showHostsPane = false;
        if (string.IsNullOrEmpty(name) || name == Agent) return;
        Nav.NavigateTo($"/agents/{name}");
    }

    private void GoBackToHosts() => _showHostsPane = true;

    private void OnSessionSelected(string? id)
    {
        if (string.IsNullOrEmpty(id) || id == SessionId) return;
        Nav.NavigateTo($"/agents/{Agent}/sessions/{id}");
    }

    private Task<IEnumerable<string>> SearchCwds(string? value, CancellationToken ct)
    {
        IEnumerable<string> results = string.IsNullOrWhiteSpace(value)
            ? _cwdSuggestions
            : _cwdSuggestions.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private static (Color color, string icon) GroupVisuals(SessionState state) => state switch
    {
        SessionState.Owned   => (Color.Success, Icons.Material.Filled.RadioButtonChecked),
        SessionState.Locked  => (Color.Warning, Icons.Material.Filled.Lock),
        SessionState.Dormant => (Color.Default, Icons.Material.Filled.History),
        _                    => (Color.Default, Icons.Material.Filled.HelpOutline),
    };

    private static string RelativeTime(DateTimeOffset when)
    {
        var delta = DateTimeOffset.UtcNow - when;
        if (delta.TotalSeconds < 60)  return "just now";
        if (delta.TotalMinutes < 60)  return $"{(int)delta.TotalMinutes}m";
        if (delta.TotalHours < 24)    return $"{(int)delta.TotalHours}h";
        if (delta.TotalDays < 7)      return $"{(int)delta.TotalDays}d";
        if (delta.TotalDays < 30)     return $"{(int)(delta.TotalDays / 7)}w";
        if (delta.TotalDays < 365)    return $"{(int)(delta.TotalDays / 30)}mo";
        return $"{(int)(delta.TotalDays / 365)}y";
    }

    private static string ShortPath(string cwd)
    {
        // Compress any /home/<user>/ prefix to ~/ for narrow display chips.
        // Generic so any deployment's user accounts collapse cleanly --
        // we don't want platform-specific user-name strings here.
        var compressed = System.Text.RegularExpressions.Regex.Replace(
            cwd, @"^/home/[^/]+/", "~/");
        if (compressed.Length <= 28) return compressed;
        return "..." + compressed[^25..];
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reset on every navigation so a previous bad route doesn't
        // stick when the user navigates to a valid one.
        _routeError = null;
        _sessionsListFailed = false;

        if (Agent is not null)
        {
            // Drop the previous agent's session list synchronously on
            // a real agent switch so the drawer doesn't briefly show
            // HENDRIK's sessions while we're loading SANDBOX's. The
            // null state renders skeletons; the post-fetch assignment
            // below replaces them. Don't do this on a same-agent
            // SessionId navigation -- the list is still valid.
            if (!string.Equals(Agent, _lastLoadedAgent, StringComparison.OrdinalIgnoreCase))
            {
                _sessions = null;
                StateHasChanged();
            }

            // First, validate the agent against our cached host list.
            // If we know what hosts exist and Agent isn't one of them,
            // bail out before hammering the hub with a doomed
            // ListSessionsAsync + SSE-stream retry storm.
            if (_agents is { Count: > 0 } &&
                !_agents.Any(a => string.Equals(a.Name, Agent, StringComparison.OrdinalIgnoreCase)))
            {
                _routeError = "agent-unknown";
            }
            else
            {
                try
                {
                    _sessions = await Hub.ListSessionsAsync(Agent);
                    _lastLoadedAgent = Agent;
                }
                catch (Exception ex)
                {
                    HubLog.LogError($"ListSessionsAsync failed for {Agent}: {ex.Message}", ex.ToString(),
                        category: nameof(Home), sessionId: SessionId,
                        extra: new { agent = Agent });
                    _sessions = [];
                    _sessionsListFailed = true;
                    Snackbar.Add($"Could not load sessions on {Agent}: {ex.Message}", Severity.Error);
                    // The agent is in our registry but unreachable right
                    // now. Surface a single clear error instead of letting
                    // the SSE pump retry 8x.
                    _routeError = "agent-offline";
                }
            }
        }

        // Session-level precondition: when ListSessionsAsync succeeded
        // but the SessionId in the URL isn't in the resulting list, the
        // user followed a stale link / typed a bad id. Skip the stream
        // dance and show a NotFound state. We deliberately only do this
        // when _sessions came from a successful fetch -- a failed fetch
        // already raised "agent-offline" above and we don't want to
        // double-report.
        if (_routeError is null
            && Agent is not null
            && SessionId is not null
            && _sessions is not null
            && !_sessionsListFailed
            && !_sessions.Any(s => s.Id == SessionId))
        {
            _routeError = "session-not-found";
        }

        // Bail out of the streaming branch entirely when the route is
        // known-bad. Cancel any leftover stream from a previous
        // (valid) route so it doesn't keep pumping into the chat.
        if (_routeError is not null)
        {
            await StopStreamingAsync();
            _streamingFor = null;
            return;
        }

        if (Agent is not null && SessionId is not null && _streamingFor != $"{Agent}/{SessionId}")
        {
            // Capture the OUTGOING session's key BEFORE we overwrite
            // _streamingFor with the new target. We need to cache the
            // current _messages under THIS key (not the new one) when
            // we snapshot below -- otherwise the new session's cache
            // entry gets polluted with the previous session's chat,
            // and the "Owned + cache present" branch happily restores
            // the wrong content into the new session's view. (This
            // exact bug manifested as "click a different session, text
            // never refreshes".)
            var previousKey = _streamingFor;

            // Claim the slot synchronously, BEFORE any awaits, so a re-entrant
            // call (cascading parameter change, navigation event, etc.) sees
            // the new target and skips this branch instead of starting a
            // duplicate stream task.
            var target = $"{Agent}/{SessionId}";
            _streamingFor = target;

            // Snapshot the OUTGOING session's ephemeral composer state
            // (queue + draft text) under its OWN key before we adopt the
            // incoming session's state. Persist alongside the in-memory
            // caches so a full refresh restores both. Per-session
            // queue + draft is the contract: a follow-up typed against
            // "investigate the bash error" isn't relevant to a different
            // session you switched to.
            if (previousKey is not null)
            {
                SnapshotMessagesAs(previousKey);
                _queueCache[previousKey] = new List<string>(_queuedMessages);
                _draftCache[previousKey] = _currentDraft;
                await PersistQueueAsync(previousKey, _queuedMessages);
                await PersistDraftAsync(previousKey, _currentDraft);
            }

            // Load the INCOMING session's queue + draft. Try the
            // in-memory cache first (fast path for same-session-tab
            // switches); fall back to localStorage so a refresh or a
            // freshly-opened tab still restores them.
            _queuedMessages.Clear();
            if (_queueCache.TryGetValue(target, out var cachedQueue))
            {
                _queuedMessages.AddRange(cachedQueue);
            }
            else
            {
                var fromStorage = await LoadQueueAsync(target);
                if (fromStorage is { Count: > 0 })
                {
                    _queuedMessages.AddRange(fromStorage);
                    _queueCache[target] = new List<string>(fromStorage);
                }
            }
            if (_draftCache.TryGetValue(target, out var cachedDraft))
            {
                _currentDraft = cachedDraft;
            }
            else
            {
                var draftFromStorage = await LoadDraftAsync(target);
                _currentDraft = draftFromStorage ?? "";
                if (!string.IsNullOrEmpty(_currentDraft))
                    _draftCache[target] = _currentDraft;
            }

            await StopStreamingAsync();
            _pendingOrphan = null;

            var info = _sessions?.FirstOrDefault(s => s.Id == SessionId);
            if (info?.State == SessionState.Locked)
            {
                // Show confirmation; user must click "Adopt" to proceed.
                _pendingOrphan = info;
                _streamingFor = $"{Agent}/{SessionId}";
                StateHasChanged();
                return;
            }

            // If we have a cached snapshot AND the session is still loaded
            // into ACP (Owned), restore the snapshot and connect WITHOUT
            // requesting a load -- ACP would reject session/load on an
            // already-loaded session.
            //
            // For Dormant sessions, request load=true so ACP loads the
            // session into its multiplex child -- BUT also pre-fetch the
            // tail of /history so we can paint the chat instantly and
            // suppress the giant replay storm that session/load would
            // otherwise stream in (see _suppressReplayEvents). Without
            // this, opening a long-running Dormant session animates every
            // historical event on top of itself.
            //
            // For Owned-without-cache (a fresh browser tab opening a
            // session that was loaded into ACP by another client, e.g.
            // the WhatsApp sidecar), neither path works: we can't
            // load=true (ACP rejects double-load) and we have no in-tab
            // cache. Fall back to reading the on-disk events.jsonl via
            // the agent's /history endpoint.
            var key = $"{Agent}/{SessionId}";
            var hasCache = _msgCache.TryGetValue(key, out var cached);
            if (hasCache && info?.State == SessionState.Owned)
            {
                await StartStreamingAsync(load: false, force: false, restoreFrom: cached);
            }
            else if (!hasCache && info?.State == SessionState.Owned)
            {
                var fromDisk = await TryLoadTailHistoryAsync(50);
                await StartStreamingAsync(load: false, force: false, restoreFrom: fromDisk);
            }
            else
            {
                // Dormant. Pre-paint from disk projection, then request
                // load=true. _suppressReplayEvents takes care of the
                // replay flood.
                var fromDisk = await TryLoadTailHistoryAsync(50);
                await StartStreamingAsync(load: true, force: false, restoreFrom: fromDisk);
            }
        }
    }

    /// <summary>
    /// Fetch the most recent <paramref name="tail"/> entries from the
    /// agent's /history endpoint (which projects events.jsonl). Sets
    /// <see cref="_oldestCursor"/> and <see cref="_hasMore"/> as a
    /// side-effect so the "Load older messages" affordance works for
    /// every caller. Returns null on error -- the caller should still
    /// start the stream, just without a pre-paint.
    /// </summary>
    private async Task<List<ChatMessage>?> TryLoadTailHistoryAsync(int tail)
    {
        if (Agent is null || SessionId is null) return null;
        try
        {
            var page = await Hub.GetHistoryAsync(Agent, SessionId, tail: tail);
            if (page is null) return null;
            _oldestCursor = page.OldestCursor;
            _hasMore = page.HasMore;
            return CollapseLegacyToolEntries(page.Entries)
                .Select(r => new ChatMessage
                {
                    Role = r.Role,
                    Text = r.Text,
                    ToolCallId = r.ToolCallId,
                    ToolStatus = r.ToolStatus,
                })
                .ToList();
        }
        catch (Exception ex)
        {
            HubLog.LogError($"GetHistoryAsync failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), sessionId: SessionId,
                extra: new { agent = Agent });
            return null;
        }
    }

    /// <summary>
    /// Pre-v0.1.8 agents projected each ACP tool call as TWO history
    /// entries: "[start] toolname" and "[end] ok|fail". Newer agents
    /// emit a single entry with <see cref="HistoryEntry.ToolStatus"/>
    /// set on the wire. Collapse the legacy two-row shape into the
    /// single-row shape so the new SPA renders a unified chip
    /// regardless of which agent version is serving it.
    /// </summary>
    private static IEnumerable<HubClient.HistoryEntry> CollapseLegacyToolEntries(
        IEnumerable<HubClient.HistoryEntry> entries)
    {
        const string startPrefix = "[start] ";
        const string endPrefix = "[end] ";
        var collapsed = new List<HubClient.HistoryEntry>();
        var indexById = new Dictionary<string, int>(StringComparer.Ordinal);
        foreach (var e in entries)
        {
            if (e.Role == "tool" && e.Text.StartsWith(startPrefix, StringComparison.Ordinal))
            {
                var title = e.Text[startPrefix.Length..];
                var collapsedEntry = e with { Text = title, ToolStatus = ToolStatus.Pending };
                if (!string.IsNullOrEmpty(e.ToolCallId))
                    indexById[e.ToolCallId] = collapsed.Count;
                collapsed.Add(collapsedEntry);
            }
            else if (e.Role == "tool" && e.Text.StartsWith(endPrefix, StringComparison.Ordinal))
            {
                var success = !e.Text.StartsWith("[end] fail", StringComparison.Ordinal);
                if (!string.IsNullOrEmpty(e.ToolCallId)
                    && indexById.TryGetValue(e.ToolCallId, out var idx))
                {
                    collapsed[idx] = collapsed[idx] with
                    {
                        ToolStatus = success ? ToolStatus.Ok : ToolStatus.Fail,
                    };
                }
                // No matching [start]: drop. The old SPA used to render
                // a standalone "[end] ok" chip; the new unified-chip
                // model has nowhere to attach it. This is a graceful
                // degradation for malformed legacy logs.
            }
            else
            {
                collapsed.Add(e);
            }
        }
        return collapsed;
    }

    /// <summary>
    /// Find the most recent "tool" message in <see cref="_messages"/>
    /// matching <paramref name="toolCallId"/>. Used by Apply() when a
    /// ToolCallEnd arrives, to mutate the existing pending chip in
    /// place. Iterates from the end since the matching start is
    /// usually the most recent tool message.
    /// </summary>
    private ChatMessage? FindToolMessage(string? toolCallId)
    {
        if (string.IsNullOrEmpty(toolCallId)) return null;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            var m = _messages[i];
            if (m.Role == "tool" && m.ToolCallId == toolCallId) return m;
        }
        return null;
    }

    private async Task ConfirmOrphanAdopt()
    {
        if (_pendingOrphan is null) return;
        var info = _pendingOrphan;
        _pendingOrphan = null;
        StateHasChanged();
        // Same Dormant treatment: pre-paint from disk, request the load,
        // suppress the replay flood. force:true kills the prior owner PID.
        var fromDisk = await TryLoadTailHistoryAsync(50);
        await StartStreamingAsync(load: true, force: true, restoreFrom: fromDisk);
    }

    private void CancelOrphanAdopt()
    {
        _pendingOrphan = null;
        _streamingFor = null;
        Nav.NavigateTo($"/agents/{Agent}");
    }

    private async Task RefreshSessions()
    {
        if (Agent is null || _sessionsRefreshing) return;
        _sessionsRefreshing = true;
        StateHasChanged();
        try
        {
            await RefreshSessionsSilentAsync();
        }
        finally
        {
            _sessionsRefreshing = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Re-fetch the session list for the current agent without
    /// touching <see cref="_sessionsRefreshing"/> (so no refresh-button
    /// spinner flicker). Used by the auto-refresh triggers --
    /// TurnComplete + tab-visibility -- to pick up name changes
    /// from `/rename` and other CLI-side mutations without the user
    /// having to click anything. Silent on failure: a transient
    /// /api/sessions blip during background refresh shouldn't pop
    /// a snackbar.
    /// </summary>
    private async Task RefreshSessionsSilentAsync()
    {
        if (Agent is null) return;
        try
        {
            var fresh = await Hub.ListSessionsAsync(Agent);
            _sessions = fresh;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            HubLog.LogWarning(
                $"Auto-refresh of sessions failed for {Agent}: {ex.Message}",
                category: nameof(Home), extra: new { agent = Agent });
            // No snackbar -- the user didn't trigger this.
        }
    }

    /// <summary>
    /// Invoked from JS when the document transitions to visible
    /// (user switched back to this SPA tab). Re-fetches the session
    /// list so any /rename or other CLI-side mutations the user made
    /// in the meantime show up immediately.
    /// </summary>
    [JSInvokable]
    public Task OnTabVisible() => RefreshSessionsSilentAsync();

    private void SelectAgent(string name)
    {
        Nav.NavigateTo($"/agents/{name}");
    }

    /// <summary>
    /// Flatten the server's session list into the order the sidebar
    /// renders it: Active (Owned -- this hub drives them) first, then
    /// Locked (held by another process). Within each state the server's
    /// UpdatedAt-DESC ordering is preserved (LINQ OrderBy is stable).
    /// Past (Dormant) sessions are excluded -- they live in the
    /// "Resume previous" dialog opened from the sessions-pane header.
    /// </summary>
    private static IEnumerable<SessionInfo> ActiveAndLockedSessions(IEnumerable<SessionInfo> sessions) =>
        sessions
            .Where(s => s.State == SessionState.Owned || s.State == SessionState.Locked)
            .OrderBy(s => s.State == SessionState.Owned ? 0 : 1);

    /// <summary>
    /// Count of Dormant ("Past") sessions for the current host -- drives
    /// both the visibility of the history toggle in the sessions-pane
    /// header and its tooltip count.
    /// </summary>
    private int PastSessionCount =>
        _sessions?.Count(s => s.State == SessionState.Dormant) ?? 0;

    /// <summary>
    /// Past sessions matching the resume-dialog search box, sorted
    /// newest first (the API already returns UpdatedAt DESC). Empty
    /// search returns all. Match is case-insensitive substring across
    /// summary, repo, branch, cwd, and session id so the user can
    /// pick whichever bit they remember.
    /// </summary>
    private List<SessionInfo> FilteredPastSessions()
    {
        if (_sessions is null) return new();
        var dormant = _sessions.Where(s => s.State == SessionState.Dormant);
        var q = _resumeSearch?.Trim();
        if (string.IsNullOrEmpty(q)) return dormant.ToList();
        return dormant
            .Where(s =>
                (s.Summary    is { } sm && sm.Contains(q, StringComparison.OrdinalIgnoreCase)) ||
                (s.Repository is { } rp && rp.Contains(q, StringComparison.OrdinalIgnoreCase)) ||
                (s.Branch     is { } br && br.Contains(q, StringComparison.OrdinalIgnoreCase)) ||
                (s.Cwd        is { } cw && cw.Contains(q, StringComparison.OrdinalIgnoreCase)) ||
                s.Id.Contains(q, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void OpenResumePanel()
    {
        _resumeSearch = "";
        _resumePanelOpen = true;
    }

    private void CancelResumePanel()
    {
        _resumePanelOpen = false;
    }

    private void OnResumeSearchChanged(string value)
    {
        _resumeSearch = value ?? "";
    }

    private void OnResumePick(string sessionId)
    {
        _resumePanelOpen = false;
        // Same route the drawer list uses; OnParametersSetAsync will
        // do the right session-state routing (Dormant -> AdoptAsync(load: true)).
        Nav.NavigateTo($"/agents/{Agent}/sessions/{sessionId}");
    }

    private void GoBackToSidebar()
    {
        // Mobile: navigate "up" from a session to the agent's session list,
        // which on narrow viewports renders as the full-width sidebar page.
        if (Agent is not null)
        {
            Nav.NavigateTo($"/agents/{Agent}");
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    private string? _currentSessionTitle =>
        _sessions?.FirstOrDefault(s => s.Id == SessionId) is { } s
            ? (s.Summary ?? s.Id[..8])
            : null;

    /// <summary>
    /// True when the current Agent advertises the "agency" flavor (i.e. the
    /// `agency` CLI is installed on that host). Used to gate the "Wrap with
    /// agency" checkbox in the new session dialog.
    /// </summary>
    private bool _currentAgentSupportsAgency =>
        _agents?.FirstOrDefault(a => a.Name == Agent)?.Flavors?.Contains("agency") == true;

    private void OpenSession(SessionInfo s)
    {
        Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
    }

    private void OpenNewSessionDialog()
    {
        if (Agent is null) return;
        // Build cwd suggestions from existing sessions (most-recent first, deduped).
        _cwdSuggestions = (_sessions ?? new())
            .Where(s => !string.IsNullOrWhiteSpace(s.Cwd))
            .OrderByDescending(s => s.UpdatedAt)
            .Select(s => s.Cwd!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(20)
            .ToList();
        _newSessionCwd = _cwdSuggestions.FirstOrDefault() ?? "";
        _newSessionUseAgency = false;
        _newSessionError = null;
        _newSessionBusy = false;
        _newSessionOpen = true;
    }

    private void CancelNewSession()
    {
        _newSessionOpen = false;
        _newSessionError = null;
    }

    private async Task ConfirmNewSession()
    {
        if (Agent is null) return;
        _newSessionBusy = true;
        _newSessionError = null;
        try
        {
            var cwd = string.IsNullOrWhiteSpace(_newSessionCwd) ? null : _newSessionCwd.Trim();
            var s = await Hub.NewSessionAsync(Agent, cwd, _newSessionUseAgency);
            if (s is null) { _newSessionError = "Server returned no session"; _newSessionBusy = false; return; }
            // Instant-insert: prepend the new session to the visible list
            // before navigating, so the user sees it appear immediately.
            _sessions ??= new List<SessionInfo>();
            if (!_sessions.Any(x => x.Id == s.Id))
                _sessions.Insert(0, s);
            _newSessionOpen = false;
            Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
            // Reconcile in the background to pick up server-filled fields.
            _ = Task.Run(async () =>
            {
                try
                {
                    var fresh = await Hub.ListSessionsAsync(Agent);
                    await InvokeAsync(() => { _sessions = fresh; StateHasChanged(); });
                }
                catch { }
            });
        }
        catch (Exception ex)
        {
            _newSessionError = ex.Message;
            _newSessionBusy = false;
        }
    }

    private async Task NewSession()
    {
        if (Agent is null) return;
        try
        {
            var s = await Hub.NewSessionAsync(Agent, null);
            if (s is not null)
            {
                _sessions = await Hub.ListSessionsAsync(Agent);
                Nav.NavigateTo($"/agents/{Agent}/sessions/{s.Id}");
            }
        }
        catch (Exception ex)
        {
            HubLog.LogError($"NewSession failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), extra: new { agent = Agent });
        }
    }

    /// <summary>
    /// Deep-clone the currently-rendered <see cref="_messages"/> into
    /// <see cref="_msgCache"/> under <paramref name="key"/> so the
    /// user can navigate away and back to a session without re-loading
    /// from the agent. Clone semantics: subsequent mutations on the
    /// observable collection (Clear, Add during streaming) don't poke
    /// the cached list.
    ///
    /// IMPORTANT: <paramref name="key"/> is explicit because the
    /// session-switch path in <see cref="OnParametersSetAsync"/> has
    /// to claim the new <see cref="_streamingFor"/> synchronously
    /// (to defend against re-entrant parameter updates) BEFORE
    /// snapshotting -- which means by the time we get here, the
    /// "current" key is the NEW session, not the one we're trying to
    /// snapshot. Passing the previous key explicitly avoids the
    /// "old session's content is cached under the new session's key"
    /// foot-gun that hid behind a single `_streamingFor` reference.
    /// </summary>
    private void SnapshotMessagesAs(string key)
    {
        if (_messages.Count == 0) return;
        _msgCache[key] = _messages
            .Select(m => new ChatMessage
            {
                Role = m.Role,
                Text = m.Text,
                ToolCallId = m.ToolCallId,
                ToolStatus = m.ToolStatus,
            })
            .ToList();
    }

    private async Task StartStreamingAsync(bool load = false, bool force = false, List<ChatMessage>? restoreFrom = null, bool isReconnect = false)
    {
        if (Agent is null || SessionId is null) return;

        // Defensive: if a previous stream task is still alive (caller didn't
        // StopStreamingAsync, or a race in OnParametersSetAsync), cancel it
        // before installing a new CTS. Without this, the old Task.Run keeps
        // pumping events into Apply() in parallel with the new one, doubling
        // every assistant chunk. (Reproduces as character-interleaving in
        // the streaming bubble.)
        if (_streamCts is not null)
        {
            try { await _streamCts.CancelAsync(); }
            catch { /* already cancelled */ }
            _streamCts.Dispose();
            _streamCts = null;
        }

        _messages.Clear();
        _streamingAssistant = null;
        if (restoreFrom is not null)
        {
            foreach (var m in restoreFrom)
                _messages.Add(new ChatMessage
                {
                    Role = m.Role,
                    Text = m.Text,
                    ToolCallId = m.ToolCallId,
                    ToolStatus = m.ToolStatus,
                });
        }
        _loading = load;
        // Drop ACP history-replay events from session/load when the chat
        // was already populated from the disk projection. See field comment.
        _suppressReplayEvents = load && restoreFrom is not null;
        if (!isReconnect)
        {
            _streamReconnectAttempts = 0;
            _streamStatus = StreamStatus.Connected;
            _reconnectNextAttemptAt = null;
            // Reset paging cursor on a real session switch UNLESS the
            // caller already populated _oldestCursor / _hasMore from a
            // pre-stream /history fetch (TryLoadTailHistoryAsync sets
            // them before calling StartStreamingAsync). If we clobber
            // unconditionally, the "Load older messages" affordance
            // never shows for Owned-no-cache or Dormant sessions.
            if (restoreFrom is null)
            {
                _oldestCursor = 0;
                _hasMore = false;
            }
        }
        _streamCts = new CancellationTokenSource();
        _streamingFor = $"{Agent}/{SessionId}";
        var ct = _streamCts.Token;
        var agent = Agent;
        var sid = SessionId;
        var streamId = ++_streamGeneration;
        Log.LogTrace("[stream {StreamId}] start agent={Agent} sid={Sid} load={Load} reconnect={IsReconnect}",
            streamId, agent, sid, load, isReconnect);
        _ = Task.Run(async () =>
        {
            var gotAnyEvent = false;
            try
            {
                try
                {
                    await foreach (var evt in Hub.StreamAsync(agent, sid, load, force, ct))
                    {
                        if (streamId != _streamGeneration)
                        {
                            // A newer stream task has taken over; this one is stale.
                            Log.LogTrace("[stream {StreamId}] stale, dropping {EventType}",
                                streamId, evt.GetType().Name);
                            return;
                        }
                        if (!gotAnyEvent && _streamReconnectAttempts > 0)
                        {
                            // First event after a reconnect cycle -- emit a
                            // Warning so /admin/logs shows the recovery, not
                            // just the previous failures. The reconnect-attempt
                            // Warning fires for each retry; this confirms the
                            // chain ended in a success rather than the
                            // give-up-after-8 path that would otherwise be the
                            // only positive-vs-negative signal.
                            HubLog.LogWarning(
                                $"[stream {streamId}] recovered after {_streamReconnectAttempts} reconnect attempt(s)",
                                category: nameof(Home), sessionId: sid,
                                extra: new { agent, generation = streamId, attempts = _streamReconnectAttempts });
                        }
                        gotAnyEvent = true;
                        _streamReconnectAttempts = 0;
                        if (_streamStatus != StreamStatus.Connected)
                        {
                            _streamStatus = StreamStatus.Connected;
                            _reconnectNextAttemptAt = null;
                        }
                        await InvokeAsync(() => Apply(evt));
                    }
                }
                catch (OperationCanceledException)
                {
                    // User navigated or component disposed. Don't reconnect.
                    return;
                }
                catch (Exception ex)
                {
                    // The stream surfaced a transport error that HubClient.StreamAsync
                    // didn't intercept (e.g. a Json deserialize blow-up inside Apply
                    // that escapes InvokeAsync, or an exception from a 3rd-party event
                    // handler). Log it, fall into the reconnect block below -- the
                    // chat should keep trying to recover, not die silently. (Prior
                    // behaviour: log + return, leaving _streamStatus stuck on
                    // Connected and the SPA frozen until refresh.)
                    HubLog.LogError($"[stream {streamId}] {ex.Message}", ex.ToString(),
                        category: nameof(Home), sessionId: sid,
                        extra: new { agent, generation = streamId });
                }

                // Reached when the SSE stream ended -- either naturally (e.g.
                // mobile browser backgrounded the tab and HubClient.StreamAsync
                // yield-broke), or after a caught exception above. If the user
                // is still on this session, transparently reconnect with the
                // existing message snapshot so the chat doesn't appear frozen.
                if (ct.IsCancellationRequested) return;
                if (streamId != _streamGeneration) return;
                if (_streamingFor != $"{agent}/{sid}") return;

                var attempt = ++_streamReconnectAttempts;
                const int maxAttempts = 8;
                if (attempt > maxAttempts)
                {
                    HubLog.LogError(
                        $"[stream {streamId}] giving up after {attempt - 1} reconnect attempts",
                        stack: null, category: nameof(Home), sessionId: sid,
                        extra: new { agent, generation = streamId });
                    _streamStatus = StreamStatus.Offline;
                    _reconnectNextAttemptAt = null;
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                // Exponential backoff capped at 10s. Note: Task.Delay is heavily
                // throttled while a tab is hidden, so a backgrounded phone won't
                // burn battery on retry storms -- the delay naturally extends
                // until the tab becomes visible again.
                var delaySec = Math.Min(10, 1 << Math.Min(attempt - 1, 4));
                // Surface every disconnect to /admin/logs so a flaky agent or
                // network shows up centrally instead of being hidden in the
                // browser's devtools console. gotAnyEvent distinguishes
                // "couldn't even connect" (suggests the agent / hub is gone)
                // from "connected then dropped mid-stream" (transient).
                HubLog.LogWarning(
                    $"[stream {streamId}] disconnected (gotAny={gotAnyEvent}); reconnect attempt {attempt} of {maxAttempts} in {delaySec}s",
                    category: nameof(Home), sessionId: sid,
                    extra: new { agent, generation = streamId, attempt, maxAttempts, delaySec, gotAnyEvent });
                Log.LogTrace("[stream {StreamId}] disconnected (gotAny={GotAny}); reconnect attempt {Attempt} in {DelaySec}s",
                    streamId, gotAnyEvent, attempt, delaySec);
                _streamStatus = StreamStatus.Reconnecting;
                _reconnectNextAttemptAt = DateTime.UtcNow.AddSeconds(delaySec);
                await InvokeAsync(StateHasChanged);
                try { await Task.Delay(TimeSpan.FromSeconds(delaySec), ct); }
                catch (OperationCanceledException) { return; }

                if (ct.IsCancellationRequested) return;
                if (streamId != _streamGeneration) return;
                if (_streamingFor != $"{agent}/{sid}") return;

                var snapshot = _messages
                    .Select(m => new ChatMessage
                    {
                        Role = m.Role,
                        Text = m.Text,
                        ToolCallId = m.ToolCallId,
                        ToolStatus = m.ToolStatus,
                    })
                    .ToList();
                await InvokeAsync(() => StartStreamingAsync(load: false, force: false, restoreFrom: snapshot, isReconnect: true));
            }
            catch (OperationCanceledException)
            {
                // Outer cancellation (component disposed mid-reconnect).
            }
            catch (Exception ex)
            {
                // Outermost catch: anything from the reconnect logic itself
                // (InvokeAsync after dispose, recursive StartStreamingAsync
                // throwing, etc.) lands here. Logged at the central sink so
                // it's debuggable, but NEVER bubbles to Blazor's unhandled-
                // exception handler (which would pop the "An unhandled error
                // has occurred. Reload" yellow banner and force a refresh).
                //
                // NOTE: also never use Console.Error.WriteLine here --
                // Blazor WASM routes stderr through dotNetCriticalError
                // which itself pops the yellow banner. Defeating the
                // whole point of catching the exception.
                HubLog.LogError($"[stream {streamId}] pump task crashed: {ex.Message}", ex.ToString(),
                    category: nameof(Home), sessionId: sid,
                    extra: new { agent, generation = streamId, fatal = true });
                // Try to surface to the user via the offline UI rather than
                // leaving the chat in a phantom-Connected state.
                try
                {
                    await InvokeAsync(() =>
                    {
                        _streamStatus = StreamStatus.Offline;
                        _reconnectNextAttemptAt = null;
                        StateHasChanged();
                    });
                }
                catch { /* component truly gone; nothing useful to do */ }
            }
        }, ct);

        if (load)
        {
            // After load completes, refresh the session list so the badge updates.
            _ = Task.Run(async () =>
            {
                while (!ct.IsCancellationRequested && _loading)
                    await Task.Delay(250, ct);
                try
                {
                    var fresh = await Hub.ListSessionsAsync(agent, ct);
                    await InvokeAsync(() => { _sessions = fresh; StateHasChanged(); });
                }
                catch { }
            }, ct);
        }
    }

    private async Task StopStreamingAsync()
    {
        CancelThinkingDebounce();
        if (_streamCts is not null)
        {
            await _streamCts.CancelAsync();
            _streamCts.Dispose();
            _streamCts = null;
        }
    }

    /// <summary>
    /// Hide the thinking dots now and re-show them if the turn goes quiet for
    /// <see cref="ThinkingDebounceMs"/> while still in flight. See the field
    /// comment on <see cref="_thinkingDebounceCts"/> for why a mid-turn lull
    /// (a silent built-in tool) needs its own indicator.
    /// </summary>
    private void ArmThinkingDebounce()
    {
        _thinking = false;
        CancelThinkingDebounce();
        var cts = new CancellationTokenSource();
        _thinkingDebounceCts = cts;
        _ = ShowThinkingAfterLullAsync(cts.Token);
    }

    private async Task ShowThinkingAfterLullAsync(CancellationToken token)
    {
        try { await Task.Delay(ThinkingDebounceMs, token); }
        catch (OperationCanceledException) { return; }
        await InvokeAsync(() =>
        {
            // A newer activity event (cancels this token), TurnComplete
            // (_busy false), or a pending approval each mean "don't show".
            Log.LogTrace("[think] lull elapsed busy={Busy} cancelled={Cancelled}",
                _busy, token.IsCancellationRequested);
            if (token.IsCancellationRequested || !_busy || _pendingApproval is not null) return;
            _thinking = true;
            StateHasChanged();
        });
    }

    private void CancelThinkingDebounce()
    {
        _thinkingDebounceCts?.Cancel();
        _thinkingDebounceCts?.Dispose();
        _thinkingDebounceCts = null;
    }

    private void Apply(StreamEvent evt)
    {
        // While ACP is replaying historical session events (between
        // LoadStarted and HistoryDone) AND the chat was already populated
        // from the disk projection (/history?tail=...), drop content
        // events so we don't double-render history on top of the tail
        // snapshot. Control events (LoadStarted/HistoryDone/LoadFailed,
        // TurnComplete, Heartbeat) still flow.
        if (_suppressReplayEvents && evt is AssistantDelta or ThoughtDelta or UserDelta
            or ToolCallStart or ToolCallProgress or ToolCallEnd or ApprovalRequired)
        {
            return;
        }
        switch (evt)
        {
            case AssistantDelta d:
                ArmThinkingDebounce();
                _streamingThought = null;
                if (_streamingAssistant is null)
                {
                    _streamingAssistant = new ChatMessage { Role = "assistant", Text = "" };
                    _messages.Add(_streamingAssistant);
                }
                _streamingAssistant.Text += d.Text;
                if (d.Text.Length <= 32)
                    Log.LogTrace("[apply] AssistantDelta gen={Gen} len={Len} text={Text}",
                        _streamGeneration, d.Text.Length, JsonSerializer.Serialize(d.Text));
                else
                    Log.LogTrace("[apply] AssistantDelta gen={Gen} len={Len}",
                        _streamGeneration, d.Text.Length);
                break;
            case ThoughtDelta td:
                ArmThinkingDebounce();
                // Finalize any in-progress assistant bubble so the next
                // assistant text starts a fresh one. A thought is the only
                // segment delimiter we get for Copilot CLI's built-in tools
                // (bash/read/write don't surface as tool_call_start -- only
                // MCP tools do), and the model almost always thinks briefly
                // between user-visible responses. Without this, consecutive
                // narration segments in one turn merge into a single bubble
                // and -- because the thought row lands between them in
                // _messages while the second segment appends to the first
                // bubble -- render out of order. Same thought-as-delimiter
                // heuristic the WhatsApp sidecar uses to split messages.
                _streamingAssistant = null;
                if (_streamingThought is null)
                {
                    _streamingThought = new ChatMessage { Role = "thought", Text = "" };
                    _messages.Add(_streamingThought);
                    _lastThoughtChunkText = null;
                }
                // Dedupe consecutive identical thought chunks. Copilot CLI
                // occasionally emits the SAME agent_thought_chunk text twice
                // back-to-back (probably the model wire's reasoning-delta
                // followed by reasoning-summary, both surfaced as the same
                // ACP kind). Without this, the user sees the same phrase
                // duplicated in the thinking bubble -- "Renaming
                // methodRenaming method" being the canonical witness.
                if (td.Text.Length > 0
                    && string.Equals(_lastThoughtChunkText, td.Text, StringComparison.Ordinal))
                {
                    break;
                }
                _streamingThought.Text += td.Text;
                _lastThoughtChunkText = td.Text;
                break;
            case UserDelta d:
                // Finalize any in-progress assistant message before starting a new turn
                // (during replay, ACP sends user_message_chunk, agent_message_chunk*, user_message_chunk, ...).
                _streamingAssistant = null;
                _streamingThought = null;
                _messages.Add(new ChatMessage { Role = "user", Text = d.Text });
                break;
            case ToolCallStart t:
                // A tool is running: nothing streams into the chat but the
                // pending chip, so show the dots to signal the turn is still
                // working. Deterministic (no debounce timer) -- the chip's
                // own appearance is the start signal.
                _thinking = true;
                CancelThinkingDebounce();
                Log.LogTrace("[think] tool start -> dots on");
                _streamingAssistant = null;
                _streamingThought = null;
                // One chip per tool call. The matching ToolCallEnd
                // mutates this same message's ToolStatus in place;
                // the chip animates Pending -> Ok / Fail without
                // leaving a separate "[end] ok" sibling row behind.
                _messages.Add(new ChatMessage
                {
                    Role = "tool",
                    ToolCallId = t.ToolCallId,
                    Text = t.Name,
                    ToolStatus = ToolStatus.Pending,
                });
                break;
            case ToolCallProgress:
                // Tool still working -- keep the dots up.
                _thinking = true;
                CancelThinkingDebounce();
                break;
            case ToolCallEnd t:
                {
                    // Tool finished; the model usually produces more output
                    // next. Keep the dots up until that arrives so the gap
                    // between tool result and next response isn't dead air.
                    _thinking = true;
                    CancelThinkingDebounce();
                    var existing = FindToolMessage(t.ToolCallId);
                    if (existing is not null)
                    {
                        existing.ToolStatus = t.Success ? ToolStatus.Ok : ToolStatus.Fail;
                    }
                    else
                    {
                        // No matching ToolCallStart. Shouldn't happen
                        // under normal wire flow but can occur if events
                        // were dropped or this stream is the result of a
                        // mid-turn reconnect. Surface the result as its
                        // own row so the user still sees something.
                        _messages.Add(new ChatMessage
                        {
                            Role = "tool",
                            ToolCallId = t.ToolCallId,
                            Text = "(orphaned tool result)",
                            ToolStatus = t.Success ? ToolStatus.Ok : ToolStatus.Fail,
                        });
                    }
                    break;
                }
            case ApprovalRequired a:
                _thinking = false;
                CancelThinkingDebounce();
                _pendingApproval = a;
                break;
            case TurnComplete:
                _thinking = false;
                CancelThinkingDebounce();
                _streamingAssistant = null;
                _streamingThought = null;
                _busy = false;
                // The session may have been /rename'd or otherwise
                // mutated during the turn (e.g. context loaded, agency
                // switched). Refresh the session list in the background
                // so the sidebar entry + AppBar title pick up the new
                // metadata without the user having to do anything.
                _ = InvokeAsync(RefreshSessionsSilentAsync);
                // Drain the queue FIFO so the next typed-while-busy
                // message fires automatically without the user having
                // to click anything. Each drained message starts a
                // fresh turn (sets _busy back to true) so subsequent
                // queue drains are serial -- no chance of two prompts
                // racing into ACP at once.
                if (_queuedMessages.Count > 0)
                {
                    var next = _queuedMessages[0];
                    _queuedMessages.RemoveAt(0);
                    PersistQueueForCurrent();
                    _ = InvokeAsync(() => SendImmediateAsync(next));
                }
                break;
            case LoadStarted:
                _loading = true;
                break;
            case HistoryDone:
                _loading = false;
                _suppressReplayEvents = false;
                _streamingAssistant = null;
                _streamingThought = null;
                break;
            case LoadFailed lf:
                _loading = false;
                _suppressReplayEvents = false;
                // session/load failure means the session genuinely
                // isn't loadable -- either the on-disk record is missing
                // (bogus / stale sessionId) or ACP refused. Don't keep
                // the SSE stream alive on what's effectively a dead
                // route; flip into the same NotFound state used for the
                // 404 pre-flight so the user sees a coherent error
                // instead of a stray "load failed: ..." tool bubble +
                // a perpetually-heartbeating stream.
                _routeError = "session-not-found";
                _ = StopStreamingAsync();
                _streamingFor = null;
                HubLog.LogWarning($"LoadFailed for {Agent}/{SessionId}: {lf.Error}",
                    category: nameof(Home), sessionId: SessionId,
                    extra: new { agent = Agent, error = lf.Error });
                break;
            case HeartbeatEvent:
                break;
        }
        StateHasChanged();
    }

    private async Task HandleSend(string text)
    {
        if (Agent is null || SessionId is null) return;
        if (_busy)
        {
            // A turn is in flight. Queue the message rather than
            // blocking the input; it'll fire FIFO on the next
            // TurnComplete (see Apply()).
            _queuedMessages.Add(text);
            PersistQueueForCurrent();
            StateHasChanged();
            return;
        }
        await SendImmediateAsync(text);
    }

    /// <summary>
    /// The actual send path. Used both for direct sends (composer's
    /// Enter while idle) and for draining the queue on TurnComplete.
    /// Adds the user bubble to the chat, flips _busy/_thinking, and
    /// dispatches through HubClient with its built-in polite-knock
    /// retry. Errors propagate as snackbars + central log entries
    /// just like the original single-path send.
    /// </summary>
    private async Task SendImmediateAsync(string text)
    {
        if (Agent is null || SessionId is null) return;
        _messages.Add(new ChatMessage { Role = "user", Text = text });
        _busy = true;
        _thinking = true;
        _pendingForceTake = null;
        try
        {
            await Hub.SendPromptAsync(Agent, SessionId, text);
        }
        catch (HostStillOwnedException ex)
        {
            // Polite knock + 60s poll already happened inside the client.
            // Stash the prompt so the user can hit "Take over" to force.
            _busy = false; _thinking = false;
            _pendingForceTake = new PendingForceTake(text, ex.HostPid);
            Snackbar.Add($"Terminal (PID {ex.HostPid}) didn't release. Click 'Take over' to force.", Severity.Warning);
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { Role = "tool", Text = $"send failed: {ex.Message}" });
            _busy = false; _thinking = false;
            Snackbar.Add($"Send failed: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    /// <summary>
    /// User clicked the Stop button next to the composer. Tells the
    /// agent to cancel the in-flight turn via POST /interrupt. The
    /// agent still emits a TurnComplete (or error) on the SSE stream,
    /// which flips _busy back to idle through Apply() -- and that's
    /// also where the queue drains, so a cancel doesn't strand
    /// queued messages.
    /// </summary>
    private async Task HandleCancel()
    {
        if (Agent is null || SessionId is null) return;
        try
        {
            await Hub.InterruptAsync(Agent, SessionId);
        }
        catch (Exception ex)
        {
            HubLog.LogError($"InterruptAsync failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), sessionId: SessionId,
                extra: new { agent = Agent });
            Snackbar.Add($"Cancel failed: {ex.Message}", Severity.Error);
        }
    }

    private void HandleDeleteQueued(int index)
    {
        if (index < 0 || index >= _queuedMessages.Count) return;
        _queuedMessages.RemoveAt(index);
        PersistQueueForCurrent();
        StateHasChanged();
    }

    private async Task HandleDraftChanged(string text)
    {
        _currentDraft = text;
        if (_streamingFor is { } key)
        {
            _draftCache[key] = text;
            await PersistDraftAsync(key, text);
        }
    }

    /// <summary>
    /// Snapshot the current <see cref="_queuedMessages"/> to the
    /// in-memory cache + localStorage for the active session. Call after
    /// any mutation site (add, dequeue, delete) so a tab refresh
    /// reflects reality.
    /// </summary>
    private void PersistQueueForCurrent()
    {
        if (_streamingFor is not { } key) return;
        _queueCache[key] = new List<string>(_queuedMessages);
        _ = PersistQueueAsync(key, _queuedMessages);
    }

    private async Task PersistDraftAsync(string sessionKey, string draft)
    {
        try
        {
            if (string.IsNullOrEmpty(draft))
                await JS.InvokeVoidAsync("localStorage.removeItem", DraftStorageKey(sessionKey));
            else
                await JS.InvokeVoidAsync("localStorage.setItem", DraftStorageKey(sessionKey), draft);
        }
        catch { /* JS interop unavailable (prerender / disposed) -- in-memory cache still holds it */ }
    }

    private async Task PersistQueueAsync(string sessionKey, IReadOnlyList<string> queue)
    {
        try
        {
            if (queue.Count == 0)
                await JS.InvokeVoidAsync("localStorage.removeItem", QueueStorageKey(sessionKey));
            else
                await JS.InvokeVoidAsync("localStorage.setItem", QueueStorageKey(sessionKey),
                    System.Text.Json.JsonSerializer.Serialize(queue));
        }
        catch { /* JS interop unavailable -- in-memory cache still holds it */ }
    }

    private async Task<string?> LoadDraftAsync(string sessionKey)
    {
        try { return await JS.InvokeAsync<string?>("localStorage.getItem", DraftStorageKey(sessionKey)); }
        catch { return null; }
    }

    private async Task<List<string>?> LoadQueueAsync(string sessionKey)
    {
        try
        {
            var raw = await JS.InvokeAsync<string?>("localStorage.getItem", QueueStorageKey(sessionKey));
            if (string.IsNullOrEmpty(raw)) return null;
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(raw);
        }
        catch
        {
            return null;
        }
    }

    /// <summary>
    /// "Take over from terminal" affordance handler. Bypasses the polite
    /// release-request and force-acquires the session via the agent so
    /// the pending prompt can land. Wraps the call so a force-take
    /// failure surfaces just as cleanly as a polite-send failure.
    /// </summary>
    private async Task HandleForceTake()
    {
        if (Agent is null || SessionId is null || _pendingForceTake is not { } pending) return;
        _busy = true; _thinking = true;
        try
        {
            await Hub.ForceTakeOverAndSendAsync(Agent, SessionId, pending.Text);
            _pendingForceTake = null;
        }
        catch (Exception ex)
        {
            _busy = false; _thinking = false;
            _messages.Add(new ChatMessage { Role = "tool", Text = $"force-take failed: {ex.Message}" });
            Snackbar.Add($"Force take-over failed: {ex.Message}", Severity.Error);
        }
        StateHasChanged();
    }

    private void HandleCancelForceTake() { _pendingForceTake = null; StateHasChanged(); }

    /// <summary>
    /// User-driven reconnect from the AppBar pill or the Offline alert.
    /// Resets the attempt counter and re-issues StartStreamingAsync as a
    /// fresh stream (not isReconnect, so the counter starts at 0 and the
    /// status flips back to Connected on the first received event).
    /// Restores the in-memory message snapshot so the user doesn't see
    /// the chat blank for a beat.
    /// </summary>
    private async Task HandleReconnectClick()
    {
        if (Agent is null || SessionId is null) return;
        _streamReconnectAttempts = 0;
        _streamStatus = StreamStatus.Reconnecting;
        _reconnectNextAttemptAt = null;
        var snapshot = _messages
            .Select(m => new ChatMessage
            {
                Role = m.Role,
                Text = m.Text,
                ToolCallId = m.ToolCallId,
                ToolStatus = m.ToolStatus,
            })
            .ToList();
        await StartStreamingAsync(load: false, force: false, restoreFrom: snapshot, isReconnect: true);
    }

    private string StreamStatusTooltip() => _streamStatus switch
    {
        StreamStatus.Connected => "Connected",
        StreamStatus.Reconnecting when _reconnectNextAttemptAt is { } at =>
            $"Reconnecting (next attempt in {Math.Max(0, (int)(at - DateTime.UtcNow).TotalSeconds)}s)...",
        StreamStatus.Reconnecting => "Reconnecting...",
        StreamStatus.Offline => "Connection dropped. Click to retry.",
        _ => "",
    };

    // Colour for the AppBar host pill outline + dot. Tracks the live
    // SSE-stream state when a session is open (so the user sees the
    // pill flip green->amber->red as the stream connects/recovers).
    // When no session is selected there's no stream to watch -- fall
    // back to the agent's static online flag.
    private Color AppBarHostColor()
    {
        if (SessionId is not null)
        {
            return _streamStatus switch
            {
                StreamStatus.Connected    => Color.Success,
                StreamStatus.Reconnecting => Color.Warning,
                StreamStatus.Offline      => Color.Error,
                _                         => Color.Default,
            };
        }
        var online = _agents?.FirstOrDefault(a => a.Name == Agent)?.Online;
        return online == true ? Color.Success : Color.Default;
    }

    // Tooltip on the host pill. Mirrors AppBarHostColor: stream-aware
    // when a session is active, agent-online-flag-aware otherwise.
    private string AppBarHostStatusText()
    {
        if (SessionId is not null)
            return $"{Agent} - {StreamStatusTooltip()}";
        var online = _agents?.FirstOrDefault(a => a.Name == Agent)?.Online;
        return online switch
        {
            true  => $"{Agent} is online",
            false => $"{Agent} is offline",
            _     => $"{Agent} status unknown",
        };
    }

    /// <summary>
    /// Demand-load the next older page of history. Invoked by ChatView
    /// when the user scrolls near the top (or clicks the "Load older
    /// messages" button). Preserves the user's visual anchor by
    /// snapshotting scroll position before the prepend and restoring
    /// after.
    /// </summary>
    private async Task HandleLoadOlder()
    {
        if (Agent is null || SessionId is null || !_hasMore || _chatView is null) return;
        var snapshot = await _chatView.SnapshotScrollAsync();
        try
        {
            var page = await Hub.GetHistoryAsync(
                Agent, SessionId,
                before: _oldestCursor, limit: 50);
            if (page is null || page.Entries.Count == 0)
            {
                _hasMore = false;
                return;
            }
            var collapsed = CollapseLegacyToolEntries(page.Entries).ToList();
            for (var i = collapsed.Count - 1; i >= 0; i--)
            {
                var r = collapsed[i];
                _messages.Insert(0, new ChatMessage
                {
                    Role = r.Role,
                    Text = r.Text,
                    ToolCallId = r.ToolCallId,
                    ToolStatus = r.ToolStatus,
                });
            }
            _oldestCursor = page.OldestCursor;
            _hasMore = page.HasMore;
        }
        catch (Exception ex)
        {
            HubLog.LogError($"HandleLoadOlder failed: {ex.Message}", ex.ToString(),
                category: nameof(Home), sessionId: SessionId,
                extra: new { agent = Agent });
        }
        await _chatView.RestoreScrollAfterPrependAsync(snapshot);
    }

    private static string TruncatePreview(string s) =>
        s.Length <= 60 ? s : s[..57] + "...";

    private async Task HandleApproval((string ApprovalId, string OptionId) a)
    {
        if (Agent is null || SessionId is null || _pendingApproval is null) return;
        await Hub.ResolveApprovalAsync(Agent, SessionId, a.ApprovalId, a.OptionId);
        _pendingApproval = null;
        StateHasChanged();
    }

    // ---- Tab-visibility refresh (auto-update on /rename etc.) ----
    private IJSObjectReference? _visibilityModule;
    private IJSObjectReference? _visibilityWatcher;
    private DotNetObjectReference<Home>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _visibilityModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/visibility.js");
            _selfRef = DotNetObjectReference.Create(this);
            _visibilityWatcher = await _visibilityModule.InvokeAsync<IJSObjectReference>(
                "watch", _selfRef);
        }
        catch (Exception ex)
        {
            // JS interop can fail during prerender or in oddball hosts;
            // a missing visibility watcher just degrades the auto-refresh
            // behaviour to "user has to click the refresh button".
            HubLog.LogWarning(
                $"Failed to install tab-visibility watcher: {ex.Message}",
                category: nameof(Home));
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_visibilityWatcher is not null)
        {
            try { await _visibilityWatcher.InvokeVoidAsync("dispose"); } catch { }
            await _visibilityWatcher.DisposeAsync();
        }
        if (_visibilityModule is not null)
            await _visibilityModule.DisposeAsync();
        _selfRef?.Dispose();

        // Component is being torn down -- snapshot the still-current
        // session under its own key so re-mounting (e.g. on hot-reload
        // during dev, or a router back-button) doesn't lose the chat.
        if (_streamingFor is not null)
            SnapshotMessagesAs(_streamingFor);
        await StopStreamingAsync();
    }
}
