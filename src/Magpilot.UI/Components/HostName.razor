@namespace Magpilot.UI.Components
@using MudBlazor

@* Inline status-dot + hostname pair. Used in two surfaces:
   * Sessions-pane drawer header (always visible whenever the drawer
     is open, on any viewport).
   * AppBar host pill (only on viewports where the drawer is
     collapsed -- i.e. below MudBlazor's Lg breakpoint -- so the
     active host is still identifiable when the drawer isn't there
     to show it).

   Callers can opt into a chip-style outlined look (Outlined=true)
   that draws a transparent-fill rounded border in the same colour
   as the status dot. The AppBar uses that look so the pill
   visually traces the connection state (green = connected, amber =
   reconnecting, red = offline, grey = unknown). The drawer header
   uses the plain inline form. *@

<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center"
          Class="@CombinedClass" Style="@CombinedStyle">
    @* Fixed-size flex slot so the static dot, the indeterminate
       spinner, and the CloudOff offline glyph all occupy the same
       visual footprint, all sharing the same vertical baseline as
       the host name. font-size + width/height use !important
       because Mud's mud-icon-size-* and mud-progress-circular-*
       classes have higher specificity than a plain inline style.
       Native title attribute (rather than MudTooltip) avoids the
       extra inline-block wrapper Mud's tooltip injects, which adds
       ~3px of vertical space and breaks slot-vs-text centering. *@
    <span class="d-inline-flex align-center justify-center"
          style="width: 1rem; height: 1rem; flex-shrink: 0; line-height: 1;"
          title="@StatusTooltip">
        @if (Indeterminate)
        {
            <MudProgressCircular Color="@EffectiveColor" Indeterminate="true"
                                 Style="width: 1rem !important; height: 1rem !important;"
                                 StrokeWidth="4" />
        }
        else
        {
            <MudIcon Icon="@StatusIcon" Color="@EffectiveColor"
                     Style="font-size: 1rem !important; width: 1rem !important; height: 1rem !important; line-height: 1;" />
        }
    </span>
    <MudText Typo="@TextTypo" Class="text-truncate" Style="min-width: 0;" title="@Agent">@Agent</MudText>
</MudStack>

@code {
    [Parameter, EditorRequired] public string Agent { get; set; } = "";

    /// <summary>
    /// True = host is online (green checked dot), false = offline
    /// (grey unchecked dot), null = state unknown (grey unchecked
    /// dot, "unknown" tooltip). Ignored when <see cref="Color"/> is
    /// set explicitly.
    /// </summary>
    [Parameter] public bool? Online { get; set; }

    /// <summary>
    /// Explicit MudBlazor colour for the status dot (and the matching
    /// border when <see cref="Outlined"/> is true). When not set, the
    /// colour is derived from <see cref="Online"/>: Success when
    /// online, Default otherwise. Use this to surface a richer state
    /// like SSE-stream Reconnecting (Color.Warning) or Offline
    /// (Color.Error) where a plain bool isn't expressive enough.
    /// </summary>
    [Parameter] public Color? Color { get; set; }

    /// <summary>
    /// Tooltip on the status dot. When unset, derived from Online.
    /// </summary>
    [Parameter] public string? StatusText { get; set; }

    /// <summary>
    /// When true, the wrapping stack draws a transparent-fill rounded
    /// border in the same colour as the dot -- "outlined chip"
    /// styling. When false, the component renders inline (just an
    /// icon+text pair next to whatever surrounds it).
    /// </summary>
    [Parameter] public bool Outlined { get; set; }

    /// <summary>
    /// When true, the status dot is replaced with an indeterminate
    /// MudProgressCircular in the same colour. Use this to convey
    /// "the state is in flux and actively converging" -- e.g. an SSE
    /// stream that is reconnecting -- so the visual encodes both the
    /// colour (which state we're heading to) and the motion (we're
    /// not stuck, we're trying).
    /// </summary>
    [Parameter] public bool Indeterminate { get; set; }

    /// <summary>Forwarded to the inner MudIcon. Defaults to Small.</summary>
    [Parameter] public Size IconSize { get; set; } = Size.Small;

    /// <summary>Forwarded to the hostname MudText. Defaults to Body2.</summary>
    [Parameter] public Typo TextTypo { get; set; } = Typo.body2;

    /// <summary>Extra class names (e.g. spacing) for the wrapping MudStack.</summary>
    [Parameter] public string? Class { get; set; }

    private MudBlazor.Color EffectiveColor =>
        Color ?? (Online == true ? MudBlazor.Color.Success : MudBlazor.Color.Default);

    private string StatusIcon
    {
        get
        {
            // Error state gets a distinctive "no connection" glyph so
            // offline reads at a glance without relying on colour
            // alone (and to mirror the previous standalone indicator
            // we removed from the AppBar). All other states share
            // the radio-button dot so the spinner-vs-dot transition
            // is the only motion: dot -> spinner -> CloudOff.
            if (EffectiveColor == MudBlazor.Color.Error)
                return Icons.Material.Filled.CloudOff;
            return EffectiveColor == MudBlazor.Color.Default
                ? Icons.Material.Filled.RadioButtonUnchecked
                : Icons.Material.Filled.RadioButtonChecked;
        }
    }

    private string StatusTooltip => StatusText
        ?? (Online switch
        {
            true  => $"{Agent} is online",
            false => $"{Agent} is offline",
            null  => $"{Agent} status unknown",
        });

    private string CombinedClass =>
        string.IsNullOrEmpty(Class) ? "" : Class;

    private string CombinedStyle
    {
        get
        {
            // The base MudStack already collapses to its content; we
            // just ensure the chrome doesn't overflow the parent flex
            // row when the hostname is long.
            var s = "min-width: 0; max-width: 100%;";
            if (Outlined)
            {
                // mud-palette-* CSS variables are theme-aware (light/dark)
                // and match the colour of the dot via MudIcon's
                // Color="@EffectiveColor". 1px solid border + radius
                // gives the standard MudBlazor "outlined chip" look but
                // without the Mud-imposed default chip padding so the
                // text typography doesn't drift away from neighbouring
                // AppBar text baselines.
                var palette = EffectiveColor switch
                {
                    MudBlazor.Color.Success  => "var(--mud-palette-success)",
                    MudBlazor.Color.Warning  => "var(--mud-palette-warning)",
                    MudBlazor.Color.Error    => "var(--mud-palette-error)",
                    MudBlazor.Color.Info     => "var(--mud-palette-info)",
                    MudBlazor.Color.Primary  => "var(--mud-palette-primary)",
                    _                        => "var(--mud-palette-action-disabled)",
                };
                s += $" border: 1px solid {palette};"
                   + " border-radius: 16px;"
                   + " padding: 2px 10px;"
                   + " background: transparent;";
            }
            return s;
        }
    }
}

