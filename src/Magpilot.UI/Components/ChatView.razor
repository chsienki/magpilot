@using System.Collections.ObjectModel
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-view-mud">
    <div class="messages-mud" @ref="_messagesEl">
        @if (HasMore)
        {
            <div class="d-flex justify-center pa-2">
                @if (_loadingMore)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Default" />
                }
                else
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.History"
                               OnClick="HandleLoadMoreClick">
                        Load older messages
                    </MudButton>
                }
            </div>
        }
        @{ _infoToolCallIds.Clear(); }
        @foreach (var m in Messages)
        {
            var isThought = m.Role.Equals("thought", StringComparison.OrdinalIgnoreCase);
            if (isThought && !ShowThoughts) { continue; }
            var roleLower = m.Role.ToLowerInvariant();

            @switch (roleLower)
            {
                case "user":
                    <div class="msg-row msg-row-user">
                        <MudPaper Elevation="0" Class="msg-bubble msg-bubble-user pa-3"
                                  Style="background-color: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">
                            <pre class="msg-text">@m.Text</pre>
                        </MudPaper>
                        <MudAvatar Size="Size.Small" Color="Color.Primary" Class="msg-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        </MudAvatar>
                    </div>
                    break;
                case "assistant":
                    <div class="msg-row msg-row-assistant">
                        <MudAvatar Size="Size.Small" Color="Color.Secondary" Class="msg-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                        </MudAvatar>
                        <MudPaper Elevation="0" Outlined="true" Class="msg-bubble msg-bubble-assistant pa-3">
                            <MarkdownView Text="@m.Text" />
                        </MudPaper>
                    </div>
                    break;
                case "thought":
                    <div class="msg-row msg-row-assistant">
                        <MudAvatar Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined" Class="msg-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" />
                        </MudAvatar>
                        <MudPaper Elevation="0" Outlined="true" Class="msg-bubble msg-bubble-thought pa-2">
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="thought-label">thinking</MudText>
                            <div class="thought-body">
                                <MarkdownView Text="@m.Text" />
                            </div>
                        </MudPaper>
                    </div>
                    break;
                case "tool":
                    {
                        // Copilot CLI emits ACP `tool_call` updates for purely
                        // informational built-ins (e.g. reading a file the model
                        // wants to look at) with a title like "Info: <path>".
                        // Those are noisier than the real edit/execute/search
                        // calls, so render them as a muted inline chip without
                        // the terminal avatar -- and track the toolCallId so
                        // the matching "[end] ok" chip can be hidden too.
                        var isInfoStart = m.Text.StartsWith("[start] Info:", StringComparison.Ordinal);
                        if (isInfoStart && !string.IsNullOrEmpty(m.ToolCallId))
                        {
                            _infoToolCallIds.Add(m.ToolCallId);
                        }
                        var isInfoEnd = m.Text.StartsWith("[end]", StringComparison.Ordinal)
                            && !string.IsNullOrEmpty(m.ToolCallId)
                            && _infoToolCallIds.Contains(m.ToolCallId);
                        if (isInfoEnd)
                        {
                            // Suppress the trailing "[end] ok" chip for info
                            // calls; the start chip already conveys what
                            // happened.
                            break;
                        }
                        if (isInfoStart)
                        {
                            var infoLabel = m.Text.Substring("[start] Info:".Length).TrimStart();
                            <div class="msg-row msg-row-info">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                         Color="Color.Default"
                                         Icon="@Icons.Material.Outlined.Info"
                                         Class="msg-tool-chip msg-tool-chip-info">@infoLabel</MudChip>
                            </div>
                        }
                        else
                        {
                            <div class="msg-row msg-row-assistant">
                                <MudAvatar Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="msg-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" />
                                </MudAvatar>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@(m.Text.StartsWith("[end] fail") ? Color.Error : (m.Text.StartsWith("[end]") ? Color.Success : Color.Default))"
                                         Icon="@(m.Text.StartsWith("[end] fail") ? Icons.Material.Filled.ErrorOutline : (m.Text.StartsWith("[end]") ? Icons.Material.Filled.CheckCircleOutline : Icons.Material.Filled.PlayArrow))"
                                         Class="msg-tool-chip">@m.Text</MudChip>
                            </div>
                        }
                    }
                    break;
                default:
                    <div class="msg-row msg-row-assistant">
                        <MudPaper Elevation="0" Outlined="true" Class="msg-bubble msg-bubble-assistant pa-3">
                            <pre class="msg-text">@m.Text</pre>
                        </MudPaper>
                    </div>
                    break;
            }
        }
        @if (Thinking)
        {
            <div class="msg-row msg-row-assistant">
                <MudAvatar Size="Size.Small" Color="Color.Secondary" Class="msg-avatar">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                </MudAvatar>
                <MudPaper Elevation="0" Outlined="true" Class="msg-bubble msg-bubble-assistant pa-3 d-flex align-center">
                    <span class="thinking-dots" aria-label="thinking"><span></span><span></span><span></span></span>
                </MudPaper>
            </div>
        }
        @if (PendingApproval is not null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Permission required</MudText>
                <MudText Typo="Typo.body2" Class="mb-3">@PendingApproval.Title</MudText>
                @if (!string.IsNullOrWhiteSpace(PendingApproval.Detail))
                {
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-3">
                        <pre class="msg-text" style="font-size: 0.85em;">@PendingApproval.Detail</pre>
                    </MudPaper>
                }
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    @foreach (var o in PendingApproval.Options)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   OnClick="@(() => OnApproval.InvokeAsync((PendingApproval.ApprovalId, o.OptionId)))">
                            @o.Label
                        </MudButton>
                    }
                </MudStack>
            </MudAlert>
        }
    </div>

    <MudPaper Elevation="0" Square="true" Class="composer-mud pa-2">
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
            <textarea @ref="_textarea" @bind="_draft" @bind:event="oninput"
                      @onkeydown="OnKeyDown"
                      class="composer-textarea"
                      placeholder="Message... (Enter to send, Shift+Enter for newline)"
                      rows="2" disabled="@Disabled"></textarea>
            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Size="Size.Medium"
                           Disabled="@(Disabled || string.IsNullOrWhiteSpace(_draft))"
                           OnClick="@Send"
                           aria-label="Send message" />
        </MudStack>
    </MudPaper>
</div>

@code {
    [Parameter, EditorRequired] public ObservableCollection<ChatMessage> Messages { get; set; } = default!;
    [Parameter] public ApprovalRequired? PendingApproval { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Thinking { get; set; }
    [Parameter] public bool ShowThoughts { get; set; } = true;
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public EventCallback<(string ApprovalId, string OptionId)> OnApproval { get; set; }
    /// <summary>
    /// True if there are older messages on the server that aren't yet
    /// loaded into <see cref="Messages"/>. Drives the "Load older
    /// messages" button + the auto-load-on-scroll-to-top trigger.
    /// </summary>
    [Parameter] public bool HasMore { get; set; }
    /// <summary>
    /// Fired when the user scrolls within ~120px of the top, OR clicks
    /// the explicit "Load older messages" button. The host should:
    ///   1. fetch the next older page of history
    ///   2. snapshot scroll position with <see cref="SnapshotScrollAsync"/>
    ///   3. prepend the fetched messages into the front of
    ///      <see cref="Messages"/>
    ///   4. call <see cref="RestoreScrollAfterPrependAsync"/> so the
    ///      user's visual anchor stays put.
    ///   5. update <see cref="HasMore"/>.
    /// </summary>
    [Parameter] public EventCallback OnLoadMore { get; set; }

    private string _draft = "";
    private ElementReference _textarea;
    private ElementReference _messagesEl;
    private IJSObjectReference? _composerModule;
    private IJSObjectReference? _scrollModule;
    private IJSObjectReference? _scrollWatcher;
    private DotNetObjectReference<ChatView>? _selfRef;
    private int _lastMessageCount;
    private bool _loadingMore;
    private readonly HashSet<string> _infoToolCallIds = new(StringComparer.Ordinal);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _composerModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/composer.js");
            await _composerModule.InvokeVoidAsync("preventBareEnterNewline", _textarea);
            _scrollModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/history-scroll.js");
            _selfRef = DotNetObjectReference.Create(this);
            _scrollWatcher = await _scrollModule.InvokeAsync<IJSObjectReference>(
                "watchScrollTop", _messagesEl, _selfRef);
            Messages.CollectionChanged += (_, _) => InvokeAsync(StateHasChanged);
        }

        // Auto-scroll on every render where the message count grew. Cheap;
        // covers both adds and incremental streaming because Apply() in
        // Home.razor calls StateHasChanged on each delta. Skipped during
        // a load-more cycle (the host handles scroll position via
        // SnapshotScrollAsync + RestoreScrollAfterPrependAsync) so we
        // don't yank the user to the bottom when they scrolled up.
        var current = Messages.Count;
        if (current != _lastMessageCount)
        {
            var grew = current > _lastMessageCount;
            _lastMessageCount = current;
            if (grew && !_loadingMore)
            {
                try { await JS.InvokeVoidAsync("magpilot.scrollToBottom", _messagesEl); }
                catch { /* JS not ready yet on first paint */ }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_scrollWatcher is not null)
        {
            try { await _scrollWatcher.InvokeVoidAsync("dispose"); } catch { /* shutdown */ }
            try { await _scrollWatcher.DisposeAsync(); } catch { }
        }
        if (_scrollModule is not null)
        {
            try { await _scrollModule.DisposeAsync(); } catch { /* shutdown */ }
        }
        if (_composerModule is not null)
        {
            try { await _composerModule.DisposeAsync(); } catch { /* shutdown */ }
        }
        _selfRef?.Dispose();
    }

    /// <summary>
    /// JS-invokable. Fired by the scroll watcher when the user scrolls
    /// near the top. Delegates to <see cref="OnLoadMore"/> with the
    /// load-more guard set so we don't double-fire while a fetch is in
    /// flight.
    /// </summary>
    [JSInvokable]
    public async Task OnNearTop()
    {
        if (!HasMore || _loadingMore) return;
        await TriggerLoadMore();
    }

    private async Task HandleLoadMoreClick()
    {
        if (!HasMore || _loadingMore) return;
        await TriggerLoadMore();
    }

    private async Task TriggerLoadMore()
    {
        _loadingMore = true;
        StateHasChanged();
        try
        {
            await OnLoadMore.InvokeAsync();
        }
        finally
        {
            _loadingMore = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Capture the current scroll position so the host can restore the
    /// user's visual anchor after prepending older messages.
    /// </summary>
    public async ValueTask<object?> SnapshotScrollAsync()
    {
        if (_scrollModule is null) return null;
        return await _scrollModule.InvokeAsync<object?>("snapshotScroll", _messagesEl);
    }

    /// <summary>
    /// Restore the visual anchor captured by <see cref="SnapshotScrollAsync"/>
    /// after prepending older messages. Call this on the render cycle
    /// AFTER the prepend has hit the DOM (typically right after the
    /// awaited fetch + the synchronous Insert calls).
    /// </summary>
    public async ValueTask RestoreScrollAfterPrependAsync(object? snapshot)
    {
        if (_scrollModule is null || snapshot is null) return;
        await _scrollModule.InvokeVoidAsync("restoreScrollAfterPrepend", _messagesEl, snapshot);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !e.CtrlKey && !e.AltKey && !e.MetaKey)
        {
            await Send();
        }
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_draft)) return;
        var text = _draft;
        _draft = "";
        await OnSend.InvokeAsync(text);
    }
}
